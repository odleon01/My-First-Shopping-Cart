  if (priceRaw===''||isNaN(+priceRaw)||+priceRaw<0) { showToast('⚠ Precio inválido','warn'); return; }
  if (stockRaw===''||isNaN(+stockRaw)||+stockRaw<0) { showToast('⚠ Stock inválido','warn'); return; }
