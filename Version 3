/* ═══════════════════════════════════════════════════════
   EXCEL IMPORT ENGINE
   Connects "Precios" + "Inventario" Excel files,
   cross-joins on Núm. de Artículo ↔ Item,
   previews results with per-row selection,
   then imports to POS inventory.
════════════════════════════════════════════════════════ */

/* ── Column definitions ──────────────────────────────
   Each entry: { key, aliases[], required, type }
   Matching is case-insensitive, accent-insensitive,
   whitespace-collapsed.
─────────────────────────────────────────────────────── */
const XL_COLS_PRECIOS = [
  { key:'brand',      aliases:['brand','marca'],                                                   required:false, type:'str'  },
  { key:'artNum',     aliases:['núm. de artículo','num. de articulo','numero de articulo',
                               'artículo','articulo','art.','item number','item no','sku'],         required:true,  type:'str'  },
  { key:'name',       aliases:['nombre del producto','nombre producto','descripcion',
                               'description','product name','nombre'],                              required:true,  type:'str'  },
  { key:'priceEmp',   aliases:['precio único al empresario','precio unico al empresario',
                               'precio empresario','empresario','precio unico'],                    required:false, type:'num'  },
  { key:'pricePub',   aliases:['precio sugerido al público','precio sugerido al publico',
                               'precio sugerido','precio público','precio publico',
                               'precio al publico','pvp'],                                          required:false, type:'num'  },
  { key:'puntos',     aliases:['puntos','points'],                                                  required:false, type:'num'  },
  { key:'valorNeg',   aliases:['valor negocio','business value','valor de negocio'],               required:false, type:'num'  },
];

const XL_COLS_INVENTARIO = [
  { key:'org',        aliases:['org','organización','organization'],                               required:false, type:'str'  },
  { key:'sub',        aliases:['sub','sub-org','suborganizacion'],                                 required:false, type:'str'  },
  { key:'item',       aliases:['item','item number','item no','sku','artículo','articulo'],         required:true,  type:'str'  },
  { key:'desc',       aliases:['item description','descripcion','description','nombre'],            required:false, type:'str'  },
  { key:'onHand',     aliases:['on-hand','on hand','onhand','existencias','stock','cantidad'],      required:true,  type:'num'  },
];

/* ── State ─────────────────────────────────────────── */
const xlState = {
  precios:     { wb: null, rows: null, colMap: {} },
  inventario:  { wb: null, rows: null, colMap: {} },
  mergedRows:  [],        // full cross-join result
  visibleRows: [],        // after filter
  priceCol:    'publico', // 'publico' | 'empresario'
  stockFallback: 'zero',  // 'zero' | 'unlimited' | 'skip'
  importMode:  'add',     // 'add' | 'update' | 'replace'
};

/* ── Normalize string for fuzzy matching ─────────────
   Removes accents, lowercases, collapses whitespace
─────────────────────────────────────────────────────── */
function xlNorm(v) {
  return String(v ?? '')
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .toLowerCase().trim().replace(/\s+/g, ' ');
}
function xlNormNum(v) {
  return parseFloat(String(v ?? '').replace(/[^0-9.\-]/g, '')) || 0;
}

/* ── Match actual column headers to expected keys ──── */
function xlMapColumns(rows, colDefs) {
  if (!rows.length) return {};
  const actualHeaders = Object.keys(rows[0]);
  const map = {};
  for (const def of colDefs) {
    const found = actualHeaders.find(h =>
      def.aliases.some(a => xlNorm(h) === xlNorm(a))
    );
    if (found) map[def.key] = found;
  }
  return map;
}

/* ── Build column chip indicators ─────────────────── */
function xlBuildChips(colDefs, colMap, containerId) {
  const el = document.getElementById(containerId);
  if (!el) return;
  el.innerHTML = colDefs.map(def => {
    const found = !!colMap[def.key];
    const cls   = found ? 'found' : def.required ? 'missing' : 'optional';
    const icon  = found ? '✓' : def.required ? '✕' : '○';
    // Use the first alias as display name
    const label = def.aliases[0].replace(/\b\w/g, l => l.toUpperCase()).substring(0, 18);
    return `<span class="xl-chip ${cls}" title="${def.key}">${icon} ${label}</span>`;
  }).join('');
}

/* ── Validate required cols are mapped ────────────── */
function xlValidate(colDefs, colMap) {
  const missing = colDefs.filter(d => d.required && !colMap[d.key]);
  return missing;
}

/* ── Drag helpers ─────────────────────────────────── */
function xlDrag(e, id)     { e.preventDefault(); document.getElementById(id).classList.add('drag'); }
function xlDragLeave(id)   { document.getElementById(id).classList.remove('drag'); }
function xlDropFile(e, type) {
  e.preventDefault();
  const id = type === 'precios' ? 'xlDropPrecios' : 'xlDropInventario';
  document.getElementById(id).classList.remove('drag');
  const file = e.dataTransfer.files[0];
  if (file) xlParseFile(file, type);
}
function xlLoadFile(input, type) {
  if (input.files[0]) xlParseFile(input.files[0], type);
  input.value = '';
}

/* ── Parse file (XLSX/XLS/CSV) via SheetJS ─────────── */
function xlParseFile(file, type) {
  const isCsv   = file.name.toLowerCase().endsWith('.csv');
  const reader  = new FileReader();

  reader.onload = e => {
    try {
      let wb;
      if (isCsv) {
        wb = XLSX.read(e.target.result, { type: 'string' });
      } else {
        wb = XLSX.read(new Uint8Array(e.target.result), { type: 'array' });
      }

      const state = type === 'precios' ? xlState.precios : xlState.inventario;
      state.wb    = wb;

      // Populate sheet selector
      const selId = type === 'precios' ? 'xlSheetPrecios' : 'xlSheetInventario';
      const sel   = document.getElementById(selId);
      sel.innerHTML = wb.SheetNames.map((n, i) =>
        `<option value="${i}">${n}</option>`
      ).join('');

      // Load first sheet by default
      xlLoadSheet(type, 0, file.name);

    } catch(err) {
      xlSetDropState(type, 'error', '✕ ' + err.message);
    }
  };

  if (isCsv) reader.readAsText(file, 'UTF-8');
  else        reader.readAsArrayBuffer(file);
}

/* ── Load a specific sheet from already-parsed WB ──── */
function xlLoadSheet(type, sheetIndex, fileName) {
  const state    = type === 'precios' ? xlState.precios : xlState.inventario;
  const colDefs  = type === 'precios' ? XL_COLS_PRECIOS : XL_COLS_INVENTARIO;
  const chipId   = type === 'precios' ? 'xlColChipsPrecios' : 'xlColChipsInventario';
  const metaId   = type === 'precios' ? 'xlMetaPrecios' : 'xlMetaInventario';
  const statusId = type === 'precios' ? 'xlStatusPrecios' : 'xlStatusInventario';

  try {
    const ws   = state.wb.Sheets[state.wb.SheetNames[sheetIndex]];
    const rows = XLSX.utils.sheet_to_json(ws, { defval: '' });

    if (!rows.length) throw new Error('La hoja está vacía');

    state.rows   = rows;
    state.colMap = xlMapColumns(rows, colDefs);

    const missing = xlValidate(colDefs, state.colMap);
    if (missing.length) {
      xlSetDropState(type, 'error',
        `✕ Columna requerida no encontrada: "${missing[0].aliases[0]}"`);
      xlBuildChips(colDefs, state.colMap, chipId);
      document.getElementById(metaId).style.display = 'flex';
      return;
    }

    xlSetDropState(type, 'loaded',
      `✓ ${rows.length} filas · hoja "${state.wb.SheetNames[sheetIndex]}"${fileName ? ' · '+fileName : ''}`);
    xlBuildChips(colDefs, state.colMap, chipId);
    document.getElementById(metaId).style.display = 'flex';

    // Enable merge when both loaded
    document.getElementById('xlMergeBtn').disabled =
      !(xlState.precios.rows && xlState.inventario.rows);

    // Refresh preview if already merged
    if (xlState.mergedRows.length) xlMergeData();

  } catch(err) {
    xlSetDropState(type, 'error', '✕ ' + err.message);
  }
}

/* sheet selector change */
function xlChangeSheet(type) {
  const selId = type === 'precios' ? 'xlSheetPrecios' : 'xlSheetInventario';
  const idx   = parseInt(document.getElementById(selId).value);
  xlLoadSheet(type, idx, '');
}

/* ── Set drop zone visual state ─────────────────────── */
function xlSetDropState(type, state, msg) {
  const dropId   = type === 'precios' ? 'xlDropPrecios' : 'xlDropInventario';
  const statusId = type === 'precios' ? 'xlStatusPrecios' : 'xlStatusInventario';
  const drop     = document.getElementById(dropId);
  const status   = document.getElementById(statusId);
  drop.classList.remove('loaded','error','drag');
  if (state !== 'idle') drop.classList.add(state);
  status.className  = state === 'loaded' ? 'xl-status ok' : state === 'error' ? 'xl-status err' : 'xl-status';
  status.textContent = msg;
}

/* ── Option toggles ─────────────────────────────────── */
function xlSetPrice(mode) {
  xlState.priceCol = mode;
  document.getElementById('xlPricePublico').classList.toggle('active',    mode==='publico');
  document.getElementById('xlPriceEmpresario').classList.toggle('active', mode==='empresario');
  if (xlState.mergedRows.length) xlRenderPreview();
}
function xlSetStockFallback(mode) {
  xlState.stockFallback = mode;
  ['zero','unlimited','skip'].forEach(m =>
    document.getElementById('xlStock'+m.charAt(0).toUpperCase()+m.slice(1))
      ?.classList.toggle('active', m===mode)
  );
  if (xlState.mergedRows.length) xlMergeData();
}
function xlSetMode(mode) {
  xlState.importMode = mode;
  ['add','update','replace'].forEach(m => {
    const btn = document.getElementById('xlMode'+m.charAt(0).toUpperCase()+m.slice(1));
    if (btn) btn.classList.toggle('active', m===mode);
  });
}

/* ── Cross-join Precios × Inventario ────────────────── */
function xlMergeData() {
  const pRows = xlState.precios.rows;
  const iRows = xlState.inventario.rows;
  if (!pRows || !iRows) return;

  const pMap = xlState.precios.colMap;
  const iMap = xlState.inventario.colMap;

  /* Build inventory lookup: Item → total On-hand (sum across Org/Sub) */
  const invMap = {};
  for (const row of iRows) {
    const itemRaw = iMap.item ? String(row[iMap.item] ?? '').trim() : '';
    const oh      = iMap.onHand ? xlNormNum(row[iMap.onHand]) : 0;
    if (!itemRaw) continue;
    invMap[itemRaw] = (invMap[itemRaw] ?? 0) + oh;
    // Also store normalized version for fuzzy match
    const itemNorm = xlNorm(itemRaw);
    if (itemNorm !== itemRaw) invMap[itemNorm] = invMap[itemRaw];
  }

  const onlyWithStock = document.getElementById('xlOnlyWithStock')?.checked;
  const merged = [];
  const seenArtNums = new Set();

  for (const row of pRows) {
    const artNumRaw = pMap.artNum ? String(row[pMap.artNum] ?? '').trim() : '';
    const name      = pMap.name   ? String(row[pMap.name]   ?? '').trim() : '';
    const brand     = pMap.brand  ? String(row[pMap.brand]  ?? '').trim() || 'General' : 'General';
    const pricePub  = pMap.pricePub  ? xlNormNum(row[pMap.pricePub])  : 0;
    const priceEmp  = pMap.priceEmp  ? xlNormNum(row[pMap.priceEmp])  : 0;
    const puntos    = pMap.puntos    ? xlNormNum(row[pMap.puntos])     : 0;
    const valorNeg  = pMap.valorNeg  ? xlNormNum(row[pMap.valorNeg])  : 0;

    if (!name) continue; // skip blank rows

    // Lookup stock: try exact first, then normalized
    let rawStock = invMap[artNumRaw];
    if (rawStock === undefined && artNumRaw)
      rawStock = invMap[xlNorm(artNumRaw)];

    const hasInv  = artNumRaw && rawStock !== undefined;
    let stock;
    if (hasInv) {
      stock = Math.max(0, Math.floor(rawStock));
    } else if (xlState.stockFallback === 'unlimited') {
      stock = 999;
    } else if (xlState.stockFallback === 'skip') {
      continue; // omit row
    } else {
      stock = 0;
    }

    if (onlyWithStock && stock === 0) continue;

    // Duplicate detection within Precios file
    const isDup = seenArtNums.has(artNumRaw) && artNumRaw !== '';
    seenArtNums.add(artNumRaw);

    // Check if product already exists in POS inventory
    const existingIdx = PRODUCTS.findIndex(p =>
      p.artNum === artNumRaw ||
      xlNorm(p.name) === xlNorm(name)
    );

    merged.push({
      artNum: artNumRaw, name, brand,
      pricePub, priceEmp, puntos, valorNeg,
      stock, hasInv, isDup,
      existingIdx,
      selected: true,
      rowTag: isDup ? 'dup' : hasInv ? 'matched' : (artNumRaw ? 'no-inv' : 'no-art'),
    });
  }

  xlState.mergedRows  = merged;
  xlState.visibleRows = [...merged];
  xlRenderPreview();
}

/* ── Render / refresh preview table ─────────────────── */
function xlRenderPreview() {
  const all   = xlState.mergedRows;
  const rows  = xlState.visibleRows;
  const empty = document.getElementById('xlEmptyState');
  const wrap  = document.getElementById('xlTableWrap');
  const foot  = document.getElementById('xlFoot');
  const head  = document.getElementById('xlPreviewHead');

  if (!all.length) {
    empty.style.display='flex'; wrap.style.display='none';
    foot.style.display='none';  head.style.display='none';
    return;
  }

  empty.style.display='none'; wrap.style.display='block';
  foot.style.display='flex';  head.style.display='flex';

  const usePub = xlState.priceCol === 'publico';
  const matched   = all.filter(r => r.hasInv).length;
  const noInv     = all.filter(r => !r.hasInv && r.artNum).length;
  const dups      = all.filter(r => r.isDup).length;
  const withPrice = all.filter(r => usePub ? r.pricePub>0 : r.priceEmp>0).length;
  const existCnt  = all.filter(r => r.existingIdx >= 0).length;
  const selected  = all.filter(r => r.selected).length;

  document.getElementById('xlStatsRow').innerHTML = `
    <div class="xl-stat"><span class="row-tag matched">✓</span><strong style="color:var(--success)">${matched}</strong> con stock</div>
    <div class="xl-stat"><span class="row-tag no-inv">?</span><strong style="color:var(--accent)">${noInv}</strong> sin inv.</div>
    ${dups ? `<div class="xl-stat"><span class="row-tag dup">!</span><strong style="color:var(--warn)">${dups}</strong> duplicados</div>` : ''}
    ${existCnt ? `<div class="xl-stat">🔄 <strong>${existCnt}</strong> ya existen</div>` : ''}
    <div class="xl-stat">💰 <strong>${withPrice}</strong> con precio</div>
    <div class="xl-stat">☑ <strong>${selected}</strong>/${all.length}</div>`;

  document.getElementById('xlTableBody').innerHTML = rows.map((r, vi) => {
    const realIdx = xlState.mergedRows.indexOf(r);
    const price   = usePub ? r.pricePub : r.priceEmp;
    const scls    = r.stock===0?'zero': r.stock<=5?'low':'ok';
    const tagLbl  = r.rowTag==='matched'?'✓ Cruzado': r.rowTag==='no-inv'?'? Sin inv.': r.rowTag==='dup'?'! Duplicado':'○ Sin art.';
    const existBadge = r.existingIdx>=0
      ? `<span style="font-size:.62rem;color:var(--info);margin-left:.3rem" title="Ya existe en inventario">🔄</span>` : '';
    return `<tr class="${r.selected?'':'xl-deselected'}" id="xlRow-${realIdx}">
      <td><input type="checkbox" ${r.selected?'checked':''} style="accent-color:var(--accent)"
        onchange="xlToggleRow(${realIdx}, this.checked)"></td>
      <td><code style="font-size:.66rem;color:var(--muted)">${r.artNum||'—'}</code></td>
      <td class="name-col" title="${r.name}">${r.name}${existBadge}</td>
      <td style="color:var(--text2);font-size:.73rem">${r.brand}</td>
      <td class="price-col">$${r.pricePub.toFixed(2)}</td>
      <td class="price-emp">$${r.priceEmp.toFixed(2)}</td>
      <td class="stock-col ${scls}">${r.stock}</td>
      <td><span class="row-tag ${r.rowTag}">${tagLbl}</span></td>
    </tr>`;
  }).join('');

  const selCnt = all.filter(r=>r.selected).length;
  document.getElementById('xlFootInfo').innerHTML =
    `<strong>${all.length}</strong> en lista · <strong style="color:var(--success)">${selCnt}</strong> seleccionados · ` +
    `<strong>${matched}</strong> con stock real`;
  document.getElementById('xlImportBtn').disabled = selCnt === 0;
  document.getElementById('xlChkAll').checked = all.every(r=>r.selected);
  document.getElementById('xlChkAll').indeterminate = selCnt>0 && selCnt<all.length;
}

/* ── Row selection ──────────────────────────────────── */
function xlToggleRow(idx, checked) {
  xlState.mergedRows[idx].selected = checked;
  xlRenderPreview();
}
function xlToggleAll(checked) {
  xlState.visibleRows.forEach(r => r.selected = checked);
  xlRenderPreview();
}

/* ── Preview filter ─────────────────────────────────── */
function xlFilterPreview(searchVal) {
  const q   = (document.getElementById('xlPreviewSearch')?.value ?? '').toLowerCase();
  const tag = document.getElementById('xlFilterTag')?.value ?? '';
  xlState.visibleRows = xlState.mergedRows.filter(r => {
    const matchQ   = !q || xlNorm(r.name).includes(q) || xlNorm(r.artNum).includes(q) || xlNorm(r.brand).includes(q);
    const matchTag = !tag || r.rowTag === tag;
    return matchQ && matchTag;
  });
  xlRenderPreview();
}

/* ── Confirm import ─────────────────────────────────── */
function xlConfirmImport() {
  const toImport = xlState.mergedRows.filter(r => r.selected);
  if (!toImport.length) return;

  const usePub = xlState.priceCol === 'publico';
  const mode   = xlState.importMode;
  let added=0, updated=0, skipped=0;

  if (mode === 'replace') {
    PRODUCTS = [];
  }

  toImport.forEach(r => {
    const price = usePub ? r.pricePub : r.priceEmp;
    if (!r.name) { skipped++; return; }

    const newProd = {
      id:       Date.now() + Math.floor(Math.random()*999999),
      name:     r.name,
      emoji:    '📦',
      price,
      stock:    r.stock,
      category: r.brand || 'General',
      artNum:   r.artNum || '',
    };

    if (mode === 'update' && r.existingIdx >= 0) {
      // Update price and stock of existing product
      PRODUCTS[r.existingIdx] = {
        ...PRODUCTS[r.existingIdx],
        price, stock: r.stock, category: r.brand || PRODUCTS[r.existingIdx].category,
      };
      updated++;
    } else if (mode === 'add' && r.existingIdx >= 0) {
      skipped++; // already exists, skip
    } else {
      PRODUCTS.push(newProd);
      added++;
    }
  });

  saveProducts(); renderProducts(); renderSidebar(); closeInventory();

  const parts = [];
  if (added)   parts.push(`${added} agregados`);
  if (updated) parts.push(`${updated} actualizados`);
  if (skipped) parts.push(`${skipped} omitidos`);
  showToast(`✅ Excel importado — ${parts.join(' · ')}`);

  xlResetState();
}

