/* ── Revenue bar chart ── */
function renderRevenueChart(sales, days) {
  const canvas = document.getElementById('chartRevenue');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  canvas.width  = canvas.offsetWidth || 500;
  canvas.height = 130;
  ctx.clearRect(0,0,canvas.width,canvas.height);

  // Build label buckets
  const buckets = {};
  const n = days === 0 ? 30 : Math.min(days, 30);
  for (let i = n-1; i >= 0; i--) {
    const d = new Date(Date.now() - i*864e5).toLocaleDateString('es-MX',{day:'2-digit',month:'2-digit'});
    buckets[d] = 0;
  }
  sales.forEach(s => {
    const d = new Date(s.id).toLocaleDateString('es-MX',{day:'2-digit',month:'2-digit'});
    if (d in buckets) buckets[d] += s.grand;
  });

  const labels = Object.keys(buckets);
  const values = Object.values(buckets);
  const maxVal = Math.max(...values, 1);

  const padL=8, padR=8, padT=10, padB=28;
  const w = canvas.width - padL - padR;
  const h = canvas.height - padT - padB;
  const barW = Math.max(2, w/labels.length - 2);
  const gap  = w/labels.length;

  // Grid lines
  ctx.strokeStyle = 'rgba(40,40,58,.6)';
  ctx.lineWidth = 1;
  [0,.25,.5,.75,1].forEach(f => {
    const y = padT + h*(1-f);
    ctx.beginPath(); ctx.moveTo(padL,y); ctx.lineTo(padL+w,y); ctx.stroke();
  });

  // Bars
  values.forEach((val, i) => {
    const bh  = (val/maxVal)*h;
    const x   = padL + i*gap + gap/2 - barW/2;
    const y   = padT + h - bh;
    const alpha = val>0 ? 1 : 0.25;
    ctx.fillStyle = val>0 ? `rgba(245,200,66,${alpha})` : 'rgba(40,40,58,.5)';
    // Rounded top
    const r = Math.min(3, barW/2, bh);
    ctx.beginPath();
    ctx.moveTo(x+r, y); ctx.lineTo(x+barW-r, y);
    ctx.quadraticCurveTo(x+barW, y, x+barW, y+r);
    ctx.lineTo(x+barW, y+bh); ctx.lineTo(x, y+bh);
    ctx.lineTo(x, y+r); ctx.quadraticCurveTo(x, y, x+r, y);
    ctx.fill();
  });

  // X labels (show every N-th)
  ctx.fillStyle = 'rgba(106,106,136,.9)';
  ctx.font = '9px Inter, sans-serif';
  ctx.textAlign = 'center';
  const step = Math.max(1, Math.floor(labels.length/10));
  labels.forEach((lbl, i) => {
    if (i % step === 0 || i === labels.length-1) {
      ctx.fillText(lbl, padL + i*gap + gap/2, canvas.height-6);
    }
  });
}

/* ── Category donut chart ── */
function renderCategoryChart(sales) {
  const canvas = document.getElementById('chartCategory');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  canvas.width  = canvas.offsetWidth || 220;
  canvas.height = 130;
  ctx.clearRect(0,0,canvas.width,canvas.height);

  // Sum revenue by category
  const catMap = {};
  sales.forEach(s => {
    s.items.forEach(it => {
      const prod = PRODUCTS.find(p => p.name === it.name);
      const cat  = prod?.category || 'General';
      catMap[cat] = (catMap[cat]||0) + it.subtotal;
    });
  });

  const entries = Object.entries(catMap).sort((a,b)=>b[1]-a[1]);
  const total   = entries.reduce((s,e)=>s+e[1],0) || 1;

  if (!entries.length) {
    ctx.fillStyle = 'rgba(106,106,136,.5)';
    ctx.font = '11px Inter, sans-serif'; ctx.textAlign='center';
    ctx.fillText('Sin datos', canvas.width/2, canvas.height/2);
    return;
  }

  const COLORS = ['#f5c842','#4a9eff','#2ecc7a','#e84057','#ff7a35','#a855f7','#06b6d4','#84cc16'];
  const cx = canvas.width*0.38, cy = canvas.height/2;
  const outerR = Math.min(cx, cy) - 8, innerR = outerR*0.55;
  let startAngle = -Math.PI/2;

  entries.forEach((e, i) => {
    const slice = (e[1]/total)*2*Math.PI;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, outerR, startAngle, startAngle+slice);
    ctx.closePath();
    ctx.fillStyle = COLORS[i % COLORS.length];
    ctx.fill();
    startAngle += slice;
  });

  // Inner hole
  ctx.beginPath();
  ctx.arc(cx, cy, innerR, 0, 2*Math.PI);
  ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--card').trim() || '#1a1a24';
  ctx.fill();

  // Center text
  ctx.fillStyle = '#eeeef5';
  ctx.font = 'bold 10px Inter, sans-serif'; ctx.textAlign='center';
  ctx.fillText(entries.length+' cats', cx, cy+4);

  // Legend
  const legendX = canvas.width*0.62;
  const lineH   = Math.min(16, (canvas.height-10) / Math.min(entries.length,7));
  ctx.font = '9px Inter, sans-serif';
  entries.slice(0,7).forEach((e,i) => {
    const y = 14 + i*lineH;
    ctx.fillStyle = COLORS[i%COLORS.length];
    ctx.fillRect(legendX, y-7, 8, 8);
    ctx.fillStyle = 'rgba(176,176,204,.9)';
    ctx.textAlign = 'left';
    const pct = ((e[1]/total)*100).toFixed(0)+'%';
    const label = e[0].length>12 ? e[0].substring(0,12)+'…' : e[0];
    ctx.fillText(`${label} ${pct}`, legendX+11, y);
  });
}

