function togglePayMethod(key) {
  payMethods[key].active = !payMethods[key].active;
  document.querySelector(`[data-method="${key}"]`).classList.toggle('active', payMethods[key].active);
  renderPayAmounts();
}

function renderPayAmounts() {
  const list    = document.getElementById('payAmountsList');
  const sumRow  = document.getElementById('paySummaryRow');
  const active  = Object.entries(payMethods).filter(([,v])=>v.active);

  if (!active.length) { list.innerHTML=''; sumRow.style.display='none'; refreshPaySummary(); return; }

  list.innerHTML = active.map(([key,v])=>`
    <div class="pay-amount-row" id="pamRow-${key}">
      <span class="pay-amt-label">${PM_LABELS[key]||key}</span>
      <input class="pay-amt-input" type="number" min="0" step="0.01"
        placeholder="$0.00" value="${v.amount}"
        oninput="payMethods['${key}'].amount=this.value;refreshPaySummary()"
        id="pamInput-${key}">
      <button class="pay-amt-remove" onclick="togglePayMethod('${key}')" title="Quitar">✕</button>
    </div>`).join('');

  sumRow.style.display = 'flex';
  refreshPaySummary();

  // Focus first empty amount
  const firstEmpty = active.find(([,v])=>!v.amount);
  if (firstEmpty) setTimeout(()=>document.getElementById(`pamInput-${firstEmpty[0]}`)?.focus(),50);
}

function refreshPaySummary() {
  const grandStr = document.getElementById('cfTotal')?.textContent||'0';
  const grand    = parseFloat(grandStr.replace(/[^0-9.]/g,''))||0;
  const active   = Object.values(payMethods).filter(v=>v.active);
  const paid     = active.reduce((s,v)=>s+(parseFloat(v.amount)||0),0);
  const pending  = Math.max(0, grand - paid);
  const change   = Math.max(0, paid - grand);

  const badge = document.getElementById('payPendingBadge');
  if (active.length) {
    badge.style.display='block';
    if (pending > 0.005) {
      badge.textContent=`Pendiente $${pending.toFixed(2)}`;
      badge.className='pay-pending-badge';
    } else {
      badge.textContent=change>0.005?`Cambio $${change.toFixed(2)}`:'✓ Cubierto';
      badge.className='pay-pending-badge ok';
    }
  } else { badge.style.display='none'; }

  document.getElementById('payTotalPaid').textContent   = `$${paid.toFixed(2)}`;
  document.getElementById('payTotalPending').textContent= `$${pending.toFixed(2)}`;
  const changeRow = document.getElementById('payChangeRow');
  if (change>0.005) {
    changeRow.style.display='flex';
    document.getElementById('payChange').textContent=`$${change.toFixed(2)}`;
  } else changeRow.style.display='none';
}

function resetPayMethods() {
  Object.keys(payMethods).forEach(k=>{ payMethods[k].active=false; payMethods[k].amount=''; });
  document.querySelectorAll('.pay-method-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('payAmountsList').innerHTML='';
  document.getElementById('paySummaryRow').style.display='none';
  document.getElementById('payPendingBadge').style.display='none';
}

/* ── Auto order number ── */
function autoOrderNum(increment) {
  const input = document.getElementById('orderNumber');
  if (!input) return;
  const stored = parseInt(localStorage.getItem('pos_lastOrder')||'0');
  const next   = increment ? stored+1 : (stored||1);
  input.value  = String(next).padStart(4,'0');
  if (increment) localStorage.setItem('pos_lastOrder', next);
}

