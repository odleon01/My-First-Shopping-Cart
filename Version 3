  ]);
  readme['!cols'] = [{wch:60}];
  XLSX.utils.book_append_sheet(wb, readme, 'Instrucciones');

  XLSX.writeFile(wb, filename);
  showToast(`✅ Plantilla ${filename} descargada`);
