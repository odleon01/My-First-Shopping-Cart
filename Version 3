<script>
/* ═══════════════════════════════════
   STATE
═══════════════════════════════════ */
const TAX = 0.16;
let PRODUCTS     = JSON.parse(localStorage.getItem('pos_products') || '[]');
let salesHistory = JSON.parse(localStorage.getItem('pos_history')  || '[]');
let cart         = {};
let discountPct  = 0;
let activeFilter = 'Todos';
let searchQuery  = '';
let viewMode     = 'grid';
let editingId    = null;

/* ── Payment methods state ── */
const PM_LABELS = {
  efectivo:'💵 Efectivo', debito:'💳 T. Débito', credito:'💳 T. Crédito',
  transferencia:'📲 Transferencia', vales:'🎟 Vales', otro:'➕ Otro'
};
const payMethods = {
  efectivo:     { active:false, amount:'' },
  debito:       { active:false, amount:'' },
  credito:      { active:false, amount:'' },
  transferencia:{ active:false, amount:'' },
  vales:        { active:false, amount:'' },
  otro:         { active:false, amount:'' },
};

/* ── CLOCK & DATE ── */
function tick() {
  const now = new Date();
  document.getElementById('clockDisplay').textContent =
    now.toLocaleTimeString('es-MX', { hour:'2-digit', minute:'2-digit', second:'2-digit' });
  document.getElementById('sbDate').textContent =
    now.toLocaleDateString('es-MX', { weekday:'short', day:'numeric', month:'short', year:'numeric' });
}
setInterval(tick, 1000); tick();

/* ── TOPBAR STATS ── */
function updateTopbarStats() {
  const today = new Date().toLocaleDateString('es-MX');
  const todaySales = salesHistory.filter(s => s.date.startsWith(today) || new Date(s.id).toLocaleDateString('es-MX') === today);
  document.getElementById('tProdCount').textContent = `${PRODUCTS.length} producto${PRODUCTS.length!==1?'s':''}`;
  document.getElementById('tTodaySales').textContent = salesHistory.length + ' total';
  document.getElementById('tTodayTotal').textContent = '$' + salesHistory.reduce((s,v)=>s+v.grand,0).toFixed(2);
  document.getElementById('sProdTotal').textContent = PRODUCTS.length;
  document.getElementById('sLowStock').textContent = PRODUCTS.filter(p=>p.stock>0&&p.stock<=5).length;
  document.getElementById('sNoStock').textContent  = PRODUCTS.filter(p=>p.stock===0).length;
}

/* ═══════════════════════════════════
   SIDEBAR CATEGORIES
═══════════════════════════════════ */
function getCategories() {
  return ['Todos', ...new Set(PRODUCTS.map(p=>p.category))];
}
function renderSidebar() {
  const cats = getCategories();
  if (!cats.includes(activeFilter)) activeFilter = 'Todos';
  document.getElementById('catList').innerHTML = cats.map(c => {
    const cnt = c === 'Todos' ? PRODUCTS.length : PRODUCTS.filter(p=>p.category===c).length;
    return `<div class="cat-item ${c===activeFilter?'active':''}" onclick="filterCat('${c.replace(/'/g,"\\'")}')">
      <span>${c}</span><span class="cat-count">${cnt}</span>
    </div>`;
  }).join('');
  updateTopbarStats();
}
function filterCat(c) { activeFilter = c; renderSidebar(); renderProducts(); }

/* ═══════════════════════════════════
   PRODUCTS CATALOG
═══════════════════════════════════ */
function setView(v) {
  viewMode = v;
  document.getElementById('vGrid').classList.toggle('active', v==='grid');
  document.getElementById('vList').classList.toggle('active', v==='list');
  renderProducts();
}

function sortProducts(arr) {
  const s = document.getElementById('sortSelect')?.value || 'name';
  return [...arr].sort((a,b) => {
    if (s==='name')      return a.name.localeCompare(b.name);
    if (s==='nameZ')     return b.name.localeCompare(a.name);
    if (s==='priceAsc')  return a.price - b.price;
    if (s==='priceDesc') return b.price - a.price;
    if (s==='stock')     return b.stock - a.stock;
    return 0;
  });
}

function renderProducts() {
  const grid = document.getElementById('productsGrid');
  grid.className = 'products-grid' + (viewMode==='list' ? ' list-view' : '');

  if (!PRODUCTS.length) {
    grid.innerHTML = `<div class="empty-state">
      <div class="es-icon">📦</div>
      <p>El inventario está vacío.<br>Agrega productos para comenzar a vender.</p>
      <button class="es-cta" onclick="openInventory()">📦 Gestionar Inventario</button>
    </div>`;
    document.getElementById('resultCount').textContent = '';
    return;
  }

  let list = PRODUCTS;
  if (activeFilter !== 'Todos') list = list.filter(p=>p.category===activeFilter);
  if (searchQuery) list = list.filter(p=>
    p.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
    p.category.toLowerCase().includes(searchQuery.toLowerCase())
  );
  list = sortProducts(list);

  document.getElementById('resultCount').innerHTML =
    `<strong>${list.length}</strong> de ${PRODUCTS.length} productos`;

  if (!list.length) {
    grid.innerHTML = `<div class="empty-state"><div class="es-icon">🔍</div><p>Sin resultados para "<strong>${searchQuery}</strong>"</p></div>`;
    return;
  }

  if (viewMode === 'list') {
    grid.innerHTML = list.map(p => `
      <div class="product-card ${p.stock===0?'out-of-stock':''}" id="pcard-${p.id}">
        <div class="list-row">
          <div class="pc-img" style="height:54px;width:64px;flex-shrink:0;font-size:1.8rem;border-radius:8px">${p.emoji||'📦'}</div>
          <div class="pc-body" style="flex:1">
            <div class="pc-name">${p.name}</div>
            <div class="pc-cat">${p.category} · ${p.stock}u en stock</div>
          </div>
          <div class="pc-footer" style="flex-shrink:0;gap:.5rem;align-items:center">
            <div class="pc-price">$${p.price.toFixed(2)}</div>
            <button class="pc-edit" onclick="event.stopPropagation();quickEdit(${p.id})">✏</button>
            <button class="pc-add" onclick="addToCart(${p.id})" ${p.stock===0?'disabled':''}>+</button>
          </div>
        </div>
      </div>`).join('');
  } else {
    grid.innerHTML = list.map(p => `
      <div class="product-card ${p.stock===0?'out-of-stock':''}" id="pcard-${p.id}" onclick="addToCart(${p.id})">
        <div class="pc-img">
          ${p.emoji||'📦'}
          <div class="pc-stock ${p.stock===0?'zero':p.stock<=5?'low':''}">
            ${p.stock>0&&p.stock<=5?'⚠ ':''}${p.stock}u
          </div>
          ${p.stock===0?'<div class="out-label">SIN STOCK</div>':''}
        </div>
        <div class="pc-body">
          <div class="pc-name">${p.name}</div>
          <div class="pc-cat">${p.category}</div>
          <div class="pc-footer">
            <div class="pc-price">$${p.price.toFixed(2)}</div>
            <div style="display:flex;gap:.25rem">
              <button class="pc-edit" onclick="event.stopPropagation();quickEdit(${p.id})">✏</button>
              <button class="pc-add" onclick="event.stopPropagation();addToCart(${p.id})" ${p.stock===0?'disabled':''}>+</button>
            </div>
          </div>
        </div>
      </div>`).join('');
  }
}

/* ═══════════════════════════════════
   CART
═══════════════════════════════════ */
function addToCart(id) {
  const prod = PRODUCTS.find(p=>p.id===id);
  if (!prod || prod.stock===0) return;
  if ((cart[id]?.qty||0) >= prod.stock) { showToast('⚠ Stock máximo alcanzado','warn'); return; }
  cart[id] = cart[id] ? {...cart[id], qty:cart[id].qty+1} : {...prod, qty:1};
  const card = document.getElementById(`pcard-${id}`);
  if (card) { card.classList.remove('added'); void card.offsetWidth; card.classList.add('added'); }
  renderCart();
  document.getElementById('sbStatus').textContent = `"${prod.name}" agregado al carrito`;
  setTimeout(()=>document.getElementById('sbStatus').textContent='Listo', 2000);
}
function changeQty(id, d) {
  if (!cart[id]) return;
  cart[id].qty += d;
  if (cart[id].qty<=0) delete cart[id];
  renderCart();
}
function clearCart() {
  cart={}; discountPct=0;
  document.getElementById('discountInput').value='';
  document.getElementById('cfDiscRow').style.display='none';
  renderCart();
}
function renderCart() {
  const el = document.getElementById('cartItems');
  const items = Object.values(cart);
  if (!items.length) {
    el.innerHTML = `<div class="cart-empty"><div class="cart-empty-ico">🛍️</div><p>El carrito está vacío.<br>Haz clic en un producto para agregarlo.</p></div>`;
    updateTotals(0);
    document.getElementById('cartCount').textContent='0';
    document.getElementById('payBtn').disabled=true;
    return;
  }
  el.innerHTML = items.map(i=>`
    <div class="cart-item">
      <div class="ci-emo">${i.emoji||'📦'}</div>
      <div class="ci-info">
        <div class="ci-name">${i.name}</div>
        <div class="ci-unit">$${i.price.toFixed(2)} c/u</div>
      </div>
      <div class="ci-sub">$${(i.price*i.qty).toFixed(2)}</div>
      <div class="qty-ctrl">
        <button class="qty-btn rmv" onclick="changeQty(${i.id},-1)">−</button>
        <span class="qty-n">${i.qty}</span>
        <button class="qty-btn" onclick="changeQty(${i.id},1)">+</button>
      </div>
    </div>`).join('');
  const sub = items.reduce((s,i)=>s+i.price*i.qty, 0);
  document.getElementById('cartCount').textContent = items.reduce((s,i)=>s+i.qty,0);
  document.getElementById('payBtn').disabled = false;
  updateTotals(sub);
}
function updateTotals(sub) {
  const disc = sub*(discountPct/100), after=sub-disc, tax=after*TAX;
  document.getElementById('cfSubtotal').textContent = `$${sub.toFixed(2)}`;
  document.getElementById('cfDisc').textContent     = `-$${disc.toFixed(2)}`;
  document.getElementById('cfTax').textContent      = `$${tax.toFixed(2)}`;
  document.getElementById('cfTotal').textContent    = `$${(after+tax).toFixed(2)}`;
}
function applyDiscount() {
  const v = parseFloat(document.getElementById('discountInput').value);
  discountPct = (!isNaN(v)&&v>=0&&v<=100) ? v : 0;
  document.getElementById('cfDiscRow').style.display = discountPct>0?'flex':'none';
  if (isNaN(v)) document.getElementById('discountInput').value='';
  updateTotals(Object.values(cart).reduce((s,i)=>s+i.price*i.qty,0));
}

