function openReceipt() {
  const items = Object.values(cart);
  if (!items.length) return;

  // Validate payments if any added
  const activePms = Object.entries(payMethods).filter(([,v])=>v.active);
  if (activePms.length > 0) {
    const paid = activePms.reduce((s,[,v])=>s+(parseFloat(v.amount)||0),0);
    const total = parseFloat(document.getElementById('cfTotal').textContent.replace('$','').replace(',',''))||0;
    if (paid < total - 0.01) {
      showToast(`⚠ Monto pagado $${paid.toFixed(2)} es menor al total $${total.toFixed(2)}`,'warn');
      return;
    }
  }

  const sub=items.reduce((s,i)=>s+i.price*i.qty,0), disc=sub*(discountPct/100),
        after=sub-disc, tax=after*TAX, grand=after+tax;
  const customer  = document.getElementById('customerName').value.trim();
  const orderNum  = document.getElementById('orderNumber').value.trim();

  document.getElementById('receiptDate').textContent =
    new Date().toLocaleString('es-MX',{dateStyle:'long',timeStyle:'short'});
  document.getElementById('receiptOrderNum').textContent = orderNum ? `# Orden: ${orderNum}` : '';
  document.getElementById('receiptCustomer').textContent = customer ? `👤 ${customer}` : '';

  document.getElementById('receiptItems').innerHTML = items.map(i=>`
    <div class="rline">
      <span class="rname">${i.emoji||'📦'} ${i.name} ×${i.qty}</span>
      <span class="rprice">$${(i.price*i.qty).toFixed(2)}</span>
    </div>`).join('');

  document.getElementById('rSubtotal').textContent=`$${sub.toFixed(2)}`;
  document.getElementById('rTax').textContent=`$${tax.toFixed(2)}`;
  document.getElementById('rTotal').textContent=`$${grand.toFixed(2)}`;
  if (discountPct>0) {
    document.getElementById('rDiscRow').style.display='flex';
    document.getElementById('rDisc').textContent=`-$${disc.toFixed(2)} (${discountPct}%)`;
  } else document.getElementById('rDiscRow').style.display='none';

  // Payment breakdown
  const pmEntries = Object.entries(payMethods).filter(([,v])=>v.active&&(parseFloat(v.amount)||0)>0);
  const pmBreak   = document.getElementById('rPaymentBreakdown');
  const pmLines   = document.getElementById('rPaymentLines');
  if (pmEntries.length) {
    pmBreak.style.display='block';
    const totalPaid = pmEntries.reduce((s,[,v])=>s+(parseFloat(v.amount)||0),0);
    const change    = totalPaid - grand;
    pmLines.innerHTML = pmEntries.map(([key,v])=>`
      <div class="rline">
        <span>${PM_LABELS[key]||key}</span>
        <span class="rprice">$${parseFloat(v.amount).toFixed(2)}</span>
      </div>`).join('');
    if (change > 0.005) {
      document.getElementById('rChangeRow').style.display='flex';
      document.getElementById('rChange').textContent=`$${change.toFixed(2)}`;
    } else document.getElementById('rChangeRow').style.display='none';
  } else {
    pmBreak.style.display='none';
  }

  document.getElementById('receiptModal').style.display='flex';
}
function confirmSale() {
  const items=Object.values(cart);
  const sub=items.reduce((s,i)=>s+i.price*i.qty,0), disc=sub*(discountPct/100),
        after=sub-disc, tax=after*TAX;
  const grand = after + tax;
  items.forEach(i=>{ const p=PRODUCTS.find(p=>p.id===i.id); if(p) p.stock=Math.max(0,p.stock-i.qty); });
  saveProducts();

  // Collect payment methods
  const pmEntries = Object.entries(payMethods)
    .filter(([,v])=>v.active&&(parseFloat(v.amount)||0)>0)
    .map(([key,v])=>({ method:key, label:PM_LABELS[key]||key, amount:parseFloat(v.amount)||0 }));
  const totalPaid = pmEntries.reduce((s,p)=>s+p.amount,0);
  const change    = Math.max(0, totalPaid - grand);

  const orderNum = document.getElementById('orderNumber').value.trim();

  salesHistory.unshift({
    id:Date.now(), date:new Date().toLocaleString('es-MX'),
    orderNum: orderNum || null,
    customer:document.getElementById('customerName').value.trim(),
    items:items.map(i=>({name:i.name,emoji:i.emoji,qty:i.qty,subtotal:i.price*i.qty})),
    subtotal:sub, discount:disc, tax, grand, discountPct,
    payments: pmEntries, change
  });
  localStorage.setItem('pos_history',JSON.stringify(salesHistory.slice(0,200)));
  document.getElementById('receiptModal').style.display='none';
  document.getElementById('customerName').value='';
  autoOrderNum(true); // auto-increment order number
  clearCart();
  resetPayMethods();
  renderProducts(); renderSidebar();
  showToast('✅ Venta registrada' + (orderNum ? ` — Orden #${orderNum}` : ''));
}

