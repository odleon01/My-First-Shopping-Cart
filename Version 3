  }

  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, type === 'precios' ? 'Precios' : 'Inventario');

  // Add a "README" sheet with instructions
  const readme = XLSX.utils.aoa_to_sheet([
    ['INSTRUCCIONES'],
    [''],
    type === 'precios' ? ['Llena la hoja "Precios" con tus productos. Cada fila = 1 producto.'] :
                         ['Llena la hoja "Inventario" con las existencias. Múltiples filas por artículo se sumarán.'],
