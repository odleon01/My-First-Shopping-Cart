    ['Columnas requeridas (no cambies los encabezados):'],
    ...(type === 'precios'
      ? [['  • BRAND — Marca del producto (se usará como categoría)'],
         ['  • Núm. de Artículo — Clave única del producto (para cruzar con Inventario)'],
         ['  • Nombre del Producto — Nombre que aparecerá en el POS'],
         ['  • Precio Único al Empresario — Precio de costo'],
         ['  • Precio Sugerido al Público — Precio de venta'],
         ['  • Puntos — Opcional'],
         ['  • Valor Negocio — Opcional']]
      : [['  • Org — Organización'],
         ['  • Sub — Sub-organización'],
         ['  • Item — Clave del artículo (debe coincidir con "Núm. de Artículo" en Precios)'],
         ['  • Item Description — Descripción (opcional)'],
         ['  • On-hand — Cantidad en existencia']]
