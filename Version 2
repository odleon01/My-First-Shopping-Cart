      <div class="rline"><span>IVA (16%)</span><span class="rprice" id="rTax"></span></div>
      <div class="rtotal"><span>TOTAL</span><span class="rval" id="rTotal"></span></div>
    </div>
    <div class="modal-foot">
      <button class="receipt-acts btn-sec" onclick="document.getElementById('receiptModal').style.display='none'">Cancelar</button>
      <button class="receipt-acts btn-pri" onclick="confirmSale()">✓ Confirmar y cobrar</button>
    </div>
  </div>
</div>

<!-- ════════ HISTORY MODAL ════════ -->

<div class="overlay" id="historyModal" style="display:none">
  <div class="modal history-modal">
    <div class="modal-head">
      <div class="modal-title">📊 Historial de Ventas</div>
      <button class="modal-close" onclick="document.getElementById('historyModal').style.display='none'">✕</button>
    </div>
    <div class="modal-body">
      <div class="history-summary" id="historySummary"></div>
      <div class="hist-list" id="historyList"></div>
    </div>
    <div class="modal-foot" style="justify-content:flex-end">
      <button class="btn-sec" style="max-width:130px" onclick="document.getElementById('historyModal').style.display='none'">Cerrar</button>
    </div>
  </div>
</div>

<script>
/* ═══════════════════════════════════
   STATE
═══════════════════════════════════ */
const TAX = 0.16;
let PRODUCTS     = JSON.parse(localStorage.getItem('pos_products') || '[]');
let salesHistory = JSON.parse(localStorage.getItem('pos_history')  || '[]');
let cart         = {};
let discountPct  = 0;
let activeFilter = 'Todos';
let searchQuery  = '';
let viewMode     = 'grid';
let editingId    = null;

/* ── CLOCK & DATE ── */
function tick() {
  const now = new Date();
  document.getElementById('clockDisplay').textContent =
    now.toLocaleTimeString('es-MX', { hour:'2-digit', minute:'2-digit', second:'2-digit' });
  document.getElementById('sbDate').textContent =
    now.toLocaleDateString('es-MX', { weekday:'short', day:'numeric', month:'short', year:'numeric' });
}
setInterval(tick, 1000); tick();

/* ── TOPBAR STATS ── */
function updateTopbarStats() {
  const today = new Date().toLocaleDateString('es-MX');
  const todaySales = salesHistory.filter(s => s.date.startsWith(today) || new Date(s.id).toLocaleDateString('es-MX') === today);
  document.getElementById('tProdCount').textContent = `${PRODUCTS.length} producto${PRODUCTS.length!==1?'s':''}`;
  document.getElementById('tTodaySales').textContent = salesHistory.length + ' total';
  document.getElementById('tTodayTotal').textContent = '$' + salesHistory.reduce((s,v)=>s+v.grand,0).toFixed(2);
  document.getElementById('sProdTotal').textContent = PRODUCTS.length;
  document.getElementById('sLowStock').textContent = PRODUCTS.filter(p=>p.stock>0&&p.stock<=5).length;
  document.getElementById('sNoStock').textContent  = PRODUCTS.filter(p=>p.stock===0).length;
}

/* ═══════════════════════════════════
   SIDEBAR CATEGORIES
═══════════════════════════════════ */
function getCategories() {
  return ['Todos', ...new Set(PRODUCTS.map(p=>p.category))];
}
function renderSidebar() {
  const cats = getCategories();
  if (!cats.includes(activeFilter)) activeFilter = 'Todos';
  document.getElementById('catList').innerHTML = cats.map(c => {
    const cnt = c === 'Todos' ? PRODUCTS.length : PRODUCTS.filter(p=>p.category===c).length;
    return `<div class="cat-item ${c===activeFilter?'active':''}" onclick="filterCat('${c.replace(/'/g,"\\'")}')">
      <span>${c}</span><span class="cat-count">${cnt}</span>
    </div>`;
  }).join('');
  updateTopbarStats();
}
function filterCat(c) { activeFilter = c; renderSidebar(); renderProducts(); }

/* ═══════════════════════════════════
   PRODUCTS CATALOG
═══════════════════════════════════ */
function setView(v) {
  viewMode = v;
  document.getElementById('vGrid').classList.toggle('active', v==='grid');
  document.getElementById('vList').classList.toggle('active', v==='list');
  renderProducts();
}

function sortProducts(arr) {
  const s = document.getElementById('sortSelect')?.value || 'name';
  return [...arr].sort((a,b) => {
    if (s==='name')      return a.name.localeCompare(b.name);
    if (s==='nameZ')     return b.name.localeCompare(a.name);
    if (s==='priceAsc')  return a.price - b.price;
    if (s==='priceDesc') return b.price - a.price;
    if (s==='stock')     return b.stock - a.stock;
    return 0;
  });
}

function renderProducts() {
  const grid = document.getElementById('productsGrid');
  grid.className = 'products-grid' + (viewMode==='list' ? ' list-view' : '');

  if (!PRODUCTS.length) {
    grid.innerHTML = `<div class="empty-state">
      <div class="es-icon">📦</div>
      <p>El inventario está vacío.<br>Agrega productos para comenzar a vender.</p>
      <button class="es-cta" onclick="openInventory()">📦 Gestionar Inventario</button>
    </div>`;
    document.getElementById('resultCount').textContent = '';
    return;
  }

  let list = PRODUCTS;
  if (activeFilter !== 'Todos') list = list.filter(p=>p.category===activeFilter);
  if (searchQuery) list = list.filter(p=>
    p.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
    p.category.toLowerCase().includes(searchQuery.toLowerCase())
  );
  list = sortProducts(list);

  document.getElementById('resultCount').innerHTML =
    `<strong>${list.length}</strong> de ${PRODUCTS.length} productos`;

  if (!list.length) {
    grid.innerHTML = `<div class="empty-state"><div class="es-icon">🔍</div><p>Sin resultados para "<strong>${searchQuery}</strong>"</p></div>`;
    return;
  }

  if (viewMode === 'list') {
    grid.innerHTML = list.map(p => `
      <div class="product-card ${p.stock===0?'out-of-stock':''}" id="pcard-${p.id}">
        <div class="list-row">
          <div class="pc-img" style="height:54px;width:64px;flex-shrink:0;font-size:1.8rem;border-radius:8px">${p.emoji||'📦'}</div>
          <div class="pc-body" style="flex:1">
            <div class="pc-name">${p.name}</div>
            <div class="pc-cat">${p.category} · ${p.stock}u en stock</div>
          </div>
          <div class="pc-footer" style="flex-shrink:0;gap:.5rem;align-items:center">
            <div class="pc-price">$${p.price.toFixed(2)}</div>
            <button class="pc-edit" onclick="event.stopPropagation();quickEdit(${p.id})">✏</button>
            <button class="pc-add" onclick="addToCart(${p.id})" ${p.stock===0?'disabled':''}>+</button>
          </div>
        </div>
      </div>`).join('');
  } else {
    grid.innerHTML = list.map(p => `
      <div class="product-card ${p.stock===0?'out-of-stock':''}" id="pcard-${p.id}" onclick="addToCart(${p.id})">
        <div class="pc-img">
          ${p.emoji||'📦'}
          <div class="pc-stock ${p.stock===0?'zero':p.stock<=5?'low':''}">
            ${p.stock>0&&p.stock<=5?'⚠ ':''}${p.stock}u
          </div>
          ${p.stock===0?'<div class="out-label">SIN STOCK</div>':''}
        </div>
        <div class="pc-body">
          <div class="pc-name">${p.name}</div>
          <div class="pc-cat">${p.category}</div>
          <div class="pc-footer">
            <div class="pc-price">$${p.price.toFixed(2)}</div>
            <div style="display:flex;gap:.25rem">
              <button class="pc-edit" onclick="event.stopPropagation();quickEdit(${p.id})">✏</button>
              <button class="pc-add" onclick="event.stopPropagation();addToCart(${p.id})" ${p.stock===0?'disabled':''}>+</button>
            </div>
          </div>
        </div>
      </div>`).join('');
  }
}

/* ═══════════════════════════════════
   CART
═══════════════════════════════════ */
function addToCart(id) {
  const prod = PRODUCTS.find(p=>p.id===id);
  if (!prod || prod.stock===0) return;
  if ((cart[id]?.qty||0) >= prod.stock) { showToast('⚠ Stock máximo alcanzado','warn'); return; }
  cart[id] = cart[id] ? {...cart[id], qty:cart[id].qty+1} : {...prod, qty:1};
  const card = document.getElementById(`pcard-${id}`);
  if (card) { card.classList.remove('added'); void card.offsetWidth; card.classList.add('added'); }
  renderCart();
  document.getElementById('sbStatus').textContent = `"${prod.name}" agregado al carrito`;
  setTimeout(()=>document.getElementById('sbStatus').textContent='Listo', 2000);
}
function changeQty(id, d) {
  if (!cart[id]) return;
  cart[id].qty += d;
  if (cart[id].qty<=0) delete cart[id];
  renderCart();
}
function clearCart() {
  cart={}; discountPct=0;
  document.getElementById('discountInput').value='';
  document.getElementById('cfDiscRow').style.display='none';
  renderCart();
}
function renderCart() {
  const el = document.getElementById('cartItems');
  const items = Object.values(cart);
  if (!items.length) {
    el.innerHTML = `<div class="cart-empty"><div class="cart-empty-ico">🛍️</div><p>El carrito está vacío.<br>Haz clic en un producto para agregarlo.</p></div>`;
    updateTotals(0);
    document.getElementById('cartCount').textContent='0';
    document.getElementById('payBtn').disabled=true;
    return;
  }
  el.innerHTML = items.map(i=>`
    <div class="cart-item">
      <div class="ci-emo">${i.emoji||'📦'}</div>
      <div class="ci-info">
        <div class="ci-name">${i.name}</div>
        <div class="ci-unit">$${i.price.toFixed(2)} c/u</div>
      </div>
      <div class="ci-sub">$${(i.price*i.qty).toFixed(2)}</div>
      <div class="qty-ctrl">
        <button class="qty-btn rmv" onclick="changeQty(${i.id},-1)">−</button>
        <span class="qty-n">${i.qty}</span>
        <button class="qty-btn" onclick="changeQty(${i.id},1)">+</button>
      </div>
    </div>`).join('');
  const sub = items.reduce((s,i)=>s+i.price*i.qty, 0);
  document.getElementById('cartCount').textContent = items.reduce((s,i)=>s+i.qty,0);
  document.getElementById('payBtn').disabled = false;
  updateTotals(sub);
}
function updateTotals(sub) {
  const disc = sub*(discountPct/100), after=sub-disc, tax=after*TAX;
  document.getElementById('cfSubtotal').textContent = `$${sub.toFixed(2)}`;
  document.getElementById('cfDisc').textContent     = `-$${disc.toFixed(2)}`;
  document.getElementById('cfTax').textContent      = `$${tax.toFixed(2)}`;
  document.getElementById('cfTotal').textContent    = `$${(after+tax).toFixed(2)}`;
}
function applyDiscount() {
  const v = parseFloat(document.getElementById('discountInput').value);
  discountPct = (!isNaN(v)&&v>=0&&v<=100) ? v : 0;
  document.getElementById('cfDiscRow').style.display = discountPct>0?'flex':'none';
  if (isNaN(v)) document.getElementById('discountInput').value='';
  updateTotals(Object.values(cart).reduce((s,i)=>s+i.price*i.qty,0));
}

/* ═══════════════════════════════════
   RECEIPT & SALE
═══════════════════════════════════ */
function openReceipt() {
  const items = Object.values(cart);
  if (!items.length) return;
  const sub=items.reduce((s,i)=>s+i.price*i.qty,0), disc=sub*(discountPct/100),
        after=sub-disc, tax=after*TAX, grand=after+tax;
  const customer = document.getElementById('customerName').value.trim();
  document.getElementById('receiptDate').textContent =
    new Date().toLocaleString('es-MX',{dateStyle:'long',timeStyle:'short'});
  document.getElementById('receiptCustomer').textContent = customer ? `👤 ${customer}` : '';
  document.getElementById('receiptItems').innerHTML = items.map(i=>`
    <div class="rline">
      <span class="rname">${i.emoji||'📦'} ${i.name} ×${i.qty}</span>
      <span class="rprice">$${(i.price*i.qty).toFixed(2)}</span>
    </div>`).join('');
  document.getElementById('rSubtotal').textContent=`$${sub.toFixed(2)}`;
  document.getElementById('rTax').textContent=`$${tax.toFixed(2)}`;
  document.getElementById('rTotal').textContent=`$${grand.toFixed(2)}`;
  if (discountPct>0) {
    document.getElementById('rDiscRow').style.display='flex';
    document.getElementById('rDisc').textContent=`-$${disc.toFixed(2)} (${discountPct}%)`;
  } else document.getElementById('rDiscRow').style.display='none';
  document.getElementById('receiptModal').style.display='flex';
}
function confirmSale() {
  const items=Object.values(cart);
  const sub=items.reduce((s,i)=>s+i.price*i.qty,0), disc=sub*(discountPct/100),
        after=sub-disc, tax=after*TAX;
  items.forEach(i=>{ const p=PRODUCTS.find(p=>p.id===i.id); if(p) p.stock=Math.max(0,p.stock-i.qty); });
  saveProducts();
  salesHistory.unshift({
    id:Date.now(), date:new Date().toLocaleString('es-MX'),
    customer:document.getElementById('customerName').value.trim(),
    items:items.map(i=>({name:i.name,emoji:i.emoji,qty:i.qty,subtotal:i.price*i.qty})),
    subtotal:sub, discount:disc, tax, grand:after+tax, discountPct
  });
  localStorage.setItem('pos_history',JSON.stringify(salesHistory.slice(0,200)));
  document.getElementById('receiptModal').style.display='none';
  document.getElementById('customerName').value='';
  clearCart(); renderProducts(); renderSidebar();
  showToast('✅ Venta registrada exitosamente');
}

/* ═══════════════════════════════════
   INVENTORY MODAL
═══════════════════════════════════ */
function openInventory() {
  switchInvTab('products');
  document.getElementById('inventoryModal').style.display='flex';
}
function closeInventory() {
  document.getElementById('inventoryModal').style.display='none';
  renderProducts(); renderSidebar();
}
function switchInvTab(t) {
  document.getElementById('invTab-products').style.display = t==='products'?'block':'none';
  document.getElementById('invTab-import').style.display   = t==='import'?'block':'none';
  document.getElementById('tab-products').classList.toggle('active', t==='products');
  document.getElementById('tab-import').classList.toggle('active', t==='import');
  if (t==='products') { renderInvList(); populateCategorySelect(); }
}

/* FORM */
function populateCategorySelect() {
  const sel = document.getElementById('fCategory');
  const cats = [...new Set(PRODUCTS.map(p=>p.category))];
  sel.innerHTML = `<option value="">— Nueva categoría —</option>`
    + cats.map(c=>`<option value="${c}">${c}</option>`).join('');
  toggleNewCat();
}
function toggleNewCat() {
  const sel = document.getElementById('fCategory');
  document.getElementById('newCatGroup').style.display = sel.value==='' ? 'block' : 'none';
}
function resetForm() {
  editingId=null;
  ['fEmoji','fName','fPrice','fStock','fNewCat'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('emojiPreview').textContent='?';
  document.getElementById('editPill').style.display='none';
  document.getElementById('formTabLabel').textContent='NUEVO PRODUCTO';
  populateCategorySelect();
}
function quickEdit(id) {
  const p=PRODUCTS.find(p=>p.id===id);
  if (!p) return;
  editingId=id;
  openInventory(); switchInvTab('products'); populateCategorySelect();
  document.getElementById('fEmoji').value=p.emoji||'';
  document.getElementById('emojiPreview').textContent=p.emoji||'?';
  document.getElementById('fName').value=p.name;
  document.getElementById('fPrice').value=p.price;
  document.getElementById('fStock').value=p.stock;
  document.getElementById('editPill').style.display='inline';
  document.getElementById('formTabLabel').textContent='EDITAR PRODUCTO';
  const sel=document.getElementById('fCategory');
  const opt=[...sel.options].find(o=>o.value===p.category);
  if (opt) { sel.value=p.category; document.getElementById('newCatGroup').style.display='none'; }
  else { sel.value=''; document.getElementById('fNewCat').value=p.category; document.getElementById('newCatGroup').style.display='block'; }
}
function saveProduct() {
  const name=document.getElementById('fName').value.trim();
  const emoji=document.getElementById('fEmoji').value.trim();
  const priceRaw=document.getElementById('fPrice').value;
  const stockRaw=document.getElementById('fStock').value;
  const catSel=document.getElementById('fCategory').value;
  const catNew=document.getElementById('fNewCat').value.trim();
  const category=catSel||catNew;
  if (!name)     { showToast('⚠ Nombre requerido','warn'); return; }
  if (!category) { showToast('⚠ Categoría requerida','warn'); return; }
  if (priceRaw===''||isNaN(+priceRaw)||+priceRaw<0) { showToast('⚠ Precio inválido','warn'); return; }
  if (stockRaw===''||isNaN(+stockRaw)||+stockRaw<0) { showToast('⚠ Stock inválido','warn'); return; }
  const price=parseFloat((+priceRaw).toFixed(2)), stock=Math.floor(+stockRaw);
  if (editingId) {
    const idx=PRODUCTS.findIndex(p=>p.id===editingId);
    if (idx>-1) PRODUCTS[idx]={...PRODUCTS[idx],name,emoji,price,stock,category};
    showToast('✅ Producto actualizado');
  } else {
    PRODUCTS.push({id:Date.now()+Math.floor(Math.random()*9999),name,emoji,price,stock,category});
    showToast('✅ Producto agregado');
  }
  saveProducts(); resetForm(); renderInvList(); renderSidebar();
}
function deleteProduct(id) {
  if (!confirm('¿Eliminar este producto?')) return;
  PRODUCTS=PRODUCTS.filter(p=>p.id!==id); delete cart[id];
  saveProducts(); renderInvList(); renderCart(); renderSidebar();
  showToast('🗑 Producto eliminado');
}
function clearAllProducts() {
  if (!confirm('¿Eliminar TODOS los productos del inventario? Esta acción no se puede deshacer.')) return;
  PRODUCTS=[]; cart={}; saveProducts(); renderInvList(); renderCart(); renderSidebar(); renderProducts();
  showToast('🗑 Inventario limpiado');
}
function saveProducts() { localStorage.setItem('pos_products',JSON.stringify(PRODUCTS)); }

/* INV LIST */
function renderInvList() {
  const q=(document.getElementById('invSearch')?.value||'').toLowerCase();
  let items=PRODUCTS;
  if(q) items=items.filter(p=>p.name.toLowerCase().includes(q)||p.category.toLowerCase().includes(q));
  document.getElementById('invCountBadge').textContent=`${items.length}/${PRODUCTS.length}`;
  const list=document.getElementById('invList');
  if (!PRODUCTS.length) { list.innerHTML=`<div class="inv-empty">📭 Sin productos. Usa el formulario de la izquierda.</div>`; return; }
  if (!items.length) { list.innerHTML=`<div class="inv-empty">😕 Sin coincidencias</div>`; return; }
  list.innerHTML=items.map(p=>`
    <div class="inv-item">
      <div class="inv-item-emo">${p.emoji||'📦'}</div>
      <div class="inv-item-info">
        <div class="inv-item-name">${p.name}</div>
        <div class="inv-item-meta">${p.category} · ${p.stock}u · $${p.price.toFixed(2)}</div>
      </div>
      <div class="inv-item-price">$${p.price.toFixed(2)}</div>
      <div class="inv-item-acts">
        <button class="iact edit" onclick="quickEdit(${p.id})" title="Editar">✏</button>
        <button class="iact del"  onclick="deleteProduct(${p.id})" title="Eliminar">🗑</button>
      </div>
    </div>`).join('');
}

/* ═══════════════════════════════════
   IMPORT / EXPORT
═══════════════════════════════════ */
function handleFileImport(input) {
  const file=input.files[0]; if (!file) return;
  const reader=new FileReader();
  reader.onload=e=>{
    try {
      let imp=[];
      if (file.name.toLowerCase().endsWith('.json')) imp=JSON.parse(e.target.result);
      else if (file.name.toLowerCase().endsWith('.csv')) imp=parseCSV(e.target.result);
      else throw new Error('Formato no soportado');
      if (!Array.isArray(imp)||!imp.length) throw new Error('Archivo vacío');
      const valid=imp.filter(p=>p.name&&p.price!==undefined);
      if (!valid.length) throw new Error('Sin registros válidos');
      valid.forEach(p=>{
        PRODUCTS.push({id:Date.now()+Math.floor(Math.random()*99999),
          name:String(p.name).trim(), emoji:String(p.emoji||'📦').trim(),
          price:parseFloat(p.price)||0, stock:parseInt(p.stock)||0, category:String(p.category||'General').trim()});
      });
      saveProducts(); renderInvList(); renderProducts(); renderSidebar();
      showToast(`✅ ${valid.length} productos importados`);
    } catch(err) { showToast('❌ '+err.message,'warn'); }
    input.value='';
  };
  reader.readAsText(file,'UTF-8');
}
function parseCSV(text) {
  const lines=text.trim().split(/\r?\n/); if (lines.length<2) return [];
  const hdr=lines[0].split(',').map(h=>h.trim().replace(/^"|"$/g,'').toLowerCase());
  return lines.slice(1).map(line=>{
    const vals=line.match(/(".*?"|[^,]+)(?=,|$)/g)||line.split(',');
    const obj={}; hdr.forEach((h,i)=>obj[h]=(vals[i]||'').trim().replace(/^"|"$/g,''));
    return obj;
  }).filter(r=>r.name);
}
function exportJSON() {
  if (!PRODUCTS.length){showToast('Sin productos','warn');return;}
  dl('inventario.json',JSON.stringify(PRODUCTS,null,2),'application/json');
}
function exportCSV() {
  if (!PRODUCTS.length){showToast('Sin productos','warn');return;}
  const rows=PRODUCTS.map(p=>`"${p.name}","${p.emoji||''}","${p.price}","${p.category}","${p.stock}"`);
  dl('inventario.csv',['name,emoji,price,category,stock',...rows].join('\n'),'text/csv;charset=utf-8;');
}
function dl(fn,content,type) {
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob(['\uFEFF'+content],{type}));
  a.download=fn; a.click();
}
// Drag & drop
const dz=document.getElementById('dropZone');
dz.addEventListener('dragover',e=>{e.preventDefault();dz.classList.add('drag');});
dz.addEventListener('dragleave',()=>dz.classList.remove('drag'));
dz.addEventListener('drop',e=>{e.preventDefault();dz.classList.remove('drag');handleFileImport({files:e.dataTransfer.files});});

/* ═══════════════════════════════════
   HISTORY
═══════════════════════════════════ */
function showHistory() {
  const total=salesHistory.reduce((s,v)=>s+v.grand,0);
  const avgTicket=salesHistory.length ? total/salesHistory.length : 0;
  document.getElementById('historySummary').innerHTML=`
    <div class="hs-card"><div class="hs-label">Total ventas</div><div class="hs-val blue">${salesHistory.length}</div></div>
    <div class="hs-card"><div class="hs-label">Ingresos totales</div><div class="hs-val yellow">$${total.toFixed(2)}</div></div>
    <div class="hs-card"><div class="hs-label">Ticket promedio</div><div class="hs-val green">$${avgTicket.toFixed(2)}</div></div>`;
  const hl=document.getElementById('historyList');
  if (!salesHistory.length) {
    hl.innerHTML=`<div style="text-align:center;color:var(--muted);padding:2rem;font-size:.88rem">📭 Sin ventas registradas</div>`;
  } else {
    hl.innerHTML=salesHistory.map(s=>`
      <div class="hist-item">
        <div class="hist-item-head">
          <span class="hist-date">${s.date}${s.customer?' · 👤 '+s.customer:''}</span>
          <span class="hist-total">$${s.grand.toFixed(2)}</span>
        </div>
        <div class="hist-items">${s.items.map(i=>`${i.emoji||'📦'} ${i.name} ×${i.qty}`).join(' &nbsp;·&nbsp; ')}</div>
      </div>`).join('');
  }
  document.getElementById('historyModal').style.display='flex';
}

/* ═══════════════════════════════════
   TOAST
═══════════════════════════════════ */
function showToast(msg, type='ok') {
  const bg = type==='warn'?'#e84057':'#2ecc7a';
  const t=Object.assign(document.createElement('div'),{textContent:msg});
  Object.assign(t.style,{
    position:'fixed',bottom:'3rem',right:'1.5rem',
    background:bg,color:'#fff',padding:'.65rem 1.1rem',
    borderRadius:'9px',fontFamily:"'Inter',sans-serif",
    fontWeight:'600',fontSize:'.82rem',zIndex:'9999',
    boxShadow:`0 6px 24px ${bg}44`,maxWidth:'300px',
    animation:'ciSlide .25s ease'
  });
  document.body.appendChild(t);
  setTimeout(()=>t.remove(),3000);
}

/* ═══════════════════════════════════
   KEYBOARD SHORTCUTS
═══════════════════════════════════ */
document.addEventListener('keydown', e => {
  const tag = document.activeElement.tagName;
  const mod = e.ctrlKey || e.metaKey;

  if (mod && e.key==='f') {
    e.preventDefault();
    document.getElementById('searchInput').focus();
    document.getElementById('searchInput').select();
  }
  if (mod && e.key==='i') { e.preventDefault(); openInventory(); }
  if (e.key==='Enter' && !document.getElementById('receiptModal').style.display.includes('none') &&
      document.getElementById('receiptModal').style.display !== '') {
    confirmSale();
  }
  if (e.key==='Enter' && document.getElementById('payBtn') && !document.getElementById('payBtn').disabled &&
      document.getElementById('receiptModal').style.display==='none' &&
      document.getElementById('inventoryModal').style.display==='none' &&
      tag!=='INPUT') {
    openReceipt();
  }
  if (e.key==='Escape') {
    ['receiptModal','historyModal'].forEach(id=>{ document.getElementById(id).style.display='none'; });
    if (document.getElementById('inventoryModal').style.display!=='none') closeInventory();
  }
});

/* close overlay on backdrop click */
['inventoryModal','receiptModal','historyModal'].forEach(id=>{
  document.getElementById(id).addEventListener('click',function(e){
    if (e.target===this) {
      if (id==='inventoryModal') closeInventory();
      else this.style.display='none';
    }
  });
});

/* search */
document.getElementById('searchInput').addEventListener('input',e=>{
  searchQuery=e.target.value; renderProducts();
});

/* ═══════════════════════════════════
   INIT
═══════════════════════════════════ */
renderSidebar();
renderProducts();
renderCart();
</script>

