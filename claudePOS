/* ══════════════════════════════════════
   Logic — funciones puras (sin side-effects)
══════════════════════════════════════ */
const Logic = {
  fmt(n) {
    return new Intl.NumberFormat(CFG.LOCALE, { style:'currency', currency:CFG.CURRENCY, minimumFractionDigits:2 }).format(n);
  },
  fmtShort(n) {
    if (n >= 1e6) return '$' + (n/1e6).toFixed(1) + 'M';
    if (n >= 1e3) return '$' + (n/1e3).toFixed(1) + 'k';
    return Logic.fmt(n);
  },
  fmtDate(ts) { return new Date(ts).toLocaleDateString('es-MX',{year:'numeric',month:'short',day:'numeric'}); },
  fmtTime(ts) { return new Date(ts).toLocaleTimeString('es-MX',{hour:'2-digit',minute:'2-digit'}); },
  calcTotals(cart) {
    const sub = cart.reduce((a,i) => a + i.price * i.qty, 0);
    const tax = sub * CFG.TAX;
    const pts = cart.reduce((a,i) => a + (i.pts||0) * i.qty, 0);
    return { subtotal:sub, tax, total:sub+tax, pts };
  },
  calcChange(payment, total) { const p = parseFloat(payment)||0; return { change:p-total, p }; },
  cartCount(cart) { return cart.reduce((a,i) => a+i.qty, 0); },
  filterProducts(products, query, cat) {
    return products.filter(p => {
      const mc = cat==='Todos' || p.cat===cat || p.categoria===cat;
      const mq = !query || p.name?.toLowerCase().includes(query) || p.descripcion?.toLowerCase().includes(query) || p.sku?.toLowerCase().includes(query);
      return mc && mq;
    });
  },
  getCategories(products) { return ['Todos',...[...new Set(products.map(p=>p.cat||p.categoria||'General'))].filter(Boolean)]; },
  salesByDay(sales) {
    const g = {};
    sales.forEach(s => { const d=new Date(s.ts).toLocaleDateString('es-MX',{month:'short',day:'numeric'}); g[d]=(g[d]||0)+s.total; });
    return Object.entries(g).slice(-7);
  },
  top5(sales) {
    const t = {};
    sales.forEach(s => s.items.forEach(i => { t[i.name]=(t[i.name]||0)+(i.qty*i.price); }));
    return Object.entries(t).sort((a,b)=>b[1]-a[1]).slice(0,5);
  },
  exportCSV(sales) {
    const h = ['ID','Fecha','Hora','Productos','Subtotal','IVA','Total','Pago','Cambio','Puntos'];
    const rows = sales.map(s => [s.id,Logic.fmtDate(s.ts),Logic.fmtTime(s.ts),s.items.map(i=>`${i.name}x${i.qty}`).join('; '),s.subtotal.toFixed(2),s.tax.toFixed(2),s.total.toFixed(2),s.payment.toFixed(2),s.change.toFixed(2),(s.pts||0)]);
    const csv = [h,...rows].map(r=>r.join(',')).join('\n');
    const b = new Blob([csv],{type:'text/csv;charset=utf-8;'});
    const a = document.createElement('a'); a.href=URL.createObjectURL(b); a.download='ventas.csv'; a.click();
  },
  buildTicket(cart, totals, payment) {
    const sep = '─'.repeat(34);
    return ['PROPOS — COMPROBANTE', new Date().toLocaleString('es-MX'), sep,
      ...cart.map(i=>`${i.name.slice(0,20).padEnd(21)}${i.qty}x ${Logic.fmt(i.price)}`),
      sep,
      `Subtotal:  ${Logic.fmt(totals.subtotal)}`,
      `IVA 16%:   ${Logic.fmt(totals.tax)}`,
      `TOTAL:     ${Logic.fmt(totals.total)}`,
      totals.pts > 0 ? `Puntos:    ${totals.pts} pts` : '',
      `Pago:      ${Logic.fmt(parseFloat(payment)||0)}`,
      `Cambio:    ${Logic.fmt((parseFloat(payment)||0) - totals.total)}`,
      sep, 'Gracias por su compra',
    ].filter(l=>l!=='').join('\n');
  },
};

