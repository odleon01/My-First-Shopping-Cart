    this._chart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: byDay.map(x=>x[0]),
        datasets:[{ label:'Ingresos', data:byDay.map(x=>parseFloat(x[1].toFixed(2))),
          backgroundColor:'rgba(240,180,41,0.2)', borderColor:'rgba(240,180,41,0.75)',
          borderWidth:1.5, borderRadius:4 }]
