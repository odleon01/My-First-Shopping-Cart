/* ══════════════════════════════════════
   Controller — coordinador principal
══════════════════════════════════════ */
const Controller = {
  _dom: {},
  _kbFP: [],     // filtered products para navegación
  _dateFrom: '', _dateTo: '',
  _sortCol: '', _sortDir: 1,

  init() {
    this._dom = {
      grid: document.getElementById('prod-grid'),
      cartList: document.getElementById('cart-list'),
      filterBar: document.getElementById('filter-bar'),
      search: document.getElementById('g-search'),
      prodCount: document.getElementById('prod-count'),
      payIn: document.getElementById('pay-in'),
      clearBtn: document.getElementById('clear-btn'),
      checkoutBtn: document.getElementById('checkout-btn'),
      clock: document.getElementById('clock'),
    };

    Toast.init();
    SalesStore.init();

    /* Inicializar VirtualScroll ANTES de restaurar inventario desde storage,
       así _spacer no es null cuando _applyInvFilters se llama en el bloque siguiente */
    VirtualScroll.init(
      document.getElementById('vscroll'),
      document.getElementById('vspacer'),
      (action, row) => {
        if (action === 'add') {
          const p = { id:row.sku, name:row.descripcion, price:row.precio, pts:row.puntos||0, sku:row.sku };
          const existing = POSState.cart.find(i => i.id === row.sku);
          if (existing) existing.qty += 1;
          else POSState.cart.push({...p, qty:1});
          this._renderPOS();
          Toast.show(`${row.descripcion} agregado al carrito`, 's');
          document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
          document.querySelector('[data-view="pos"]').classList.add('active');
          document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
          document.getElementById('v-pos').classList.add('active');
        }
      }
    );

    /* Intentar cargar inventario guardado */
    if (InventoryStore.loadFromStorage()) {
      POSState.syncFromInventory();
      this._showInvLoaded();
      this._populateCatFilter();
      this._applyInvFilters();
      updateAlertBadge();
      AlertsRender.render();
      Toast.show('Inventario restaurado desde sesión anterior', 'i');
    }

    this._bindNav();
    this._bindPOS();
    this._bindInventory();
    this._bindDashboard();
    this._bindKeyboard();
    this._startClock();
    this._renderPOS();
  },

  /* ── Render POS completo ── */
  _renderPOS() {
    const fp = Logic.filterProducts(POSState.products, POSState.search, POSState.category);
    this._kbFP = fp;
    const cats = Logic.getCategories(POSState.products);
    const totals = Logic.calcTotals(POSState.cart);
    const count = Logic.cartCount(POSState.cart);

    Render.filters(this._dom.filterBar, cats, POSState.category);
    Render.products(this._dom.grid, fp, POSState.hlIdx);
    Render.cart(this._dom.cartList, POSState.cart);
    Render.totals(totals, count, this._dom.payIn.value);
    this._dom.prodCount.textContent = `${fp.length} de ${POSState.products.length} productos`;

    Storage.set(CFG.SK_CART, POSState.cart);

    if (POSState.hlIdx >= 0) {
      const cards = this._dom.grid.querySelectorAll('.pc');
      cards[POSState.hlIdx]?.scrollIntoView({block:'nearest',behavior:'smooth'});
    }
  },

  /* ── Navegación entre vistas ── */
  _bindNav() {
    document.querySelectorAll('.nav-item[data-view]').forEach(btn => {
      btn.addEventListener('click', () => {
        const view = btn.dataset.view;
        document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
        document.getElementById(`v-${view}`)?.classList.add('active');

        if (view === 'dashboard') Render.dashboard(this._dateFrom, this._dateTo);
        if (view === 'alerts') AlertsRender.render();
        if (view === 'inventory') VirtualScroll.refresh();
      });
    });
  },

  /* ── POS events ── */
  _bindPOS() {
    const ds = this._debounce(v => { POSState.search=v.toLowerCase().trim(); POSState.hlIdx=-1; this._renderPOS(); }, CFG.DEBOUNCE_MS);
    this._dom.search.addEventListener('input', e => ds(e.target.value));

    this._dom.filterBar.addEventListener('click', e => {
      const b = e.target.closest('.f-btn');
      if (b) { POSState.category = b.dataset.cat; POSState.hlIdx=-1; this._renderPOS(); }
    });

    this._dom.grid.addEventListener('click', e => {
      const card = e.target.closest('.pc');
      const add  = e.target.closest('.pc-add');
      const id   = card?.dataset.id || add?.dataset.id;
      if (id) this._addToCart(id);
    });

    this._dom.cartList.addEventListener('click', e => {
      const b = e.target.closest('.qb');
      if (!b) return;
      const pid   = b.dataset.pid;
      const delta = parseInt(b.dataset.d, 10);
      if (!isNaN(delta)) {
        const item = POSState.cart.find(i=>i.id===pid);
        if (!item) return;
        item.qty += delta;
        if (item.qty <= 0) POSState.cart = POSState.cart.filter(i=>i.id!==pid);
      } else {
        POSState.cart = POSState.cart.filter(i=>i.id!==pid);
        Toast.show('Producto eliminado','i');
      }
      this._renderPOS();
    });

    this._dom.payIn.addEventListener('input', () => {
      const t = Logic.calcTotals(POSState.cart);
      Render.totals(t, Logic.cartCount(POSState.cart), this._dom.payIn.value);
    });

    this._dom.clearBtn.addEventListener('click', () => {
      if (!POSState.cart.length) return;
      POSState.cart = []; this._dom.payIn.value='';
      this._renderPOS(); Toast.show('Orden limpiada','i');
    });

    this._dom.checkoutBtn.addEventListener('click', () => this._checkout());
  },

  /* ── Agregar al carrito ── */
  _addToCart(id) {
    const product = POSState.products.find(p => p.id===id);
    if (!product) return;
    const existing = POSState.cart.find(i => i.id===id);
    if (existing) existing.qty += 1;
    else POSState.cart.push({ id:product.id, name:product.name, price:product.price, pts:product.pts||0, qty:1, sku:product.sku||product.id });
    this._renderPOS();
    Toast.show(`${product.name} agregado`,'s');
  },

  /* ── Checkout ── */
  _checkout() {
    const totals = Logic.calcTotals(POSState.cart);
    const payment = parseFloat(this._dom.payIn.value)||0;
    if (!POSState.cart.length) { Toast.show('El carrito está vacío','e'); return; }
    if (payment < totals.total) { Toast.show('Pago insuficiente','e'); return; }

    const saleId = 'V' + String(SalesStore.getAll().length+1).padStart(3,'0');
    const sale = {
      id: saleId, ts: Date.now(),
      items: POSState.cart.map(i=>({ sku:i.sku||i.id, name:i.name, price:i.price, pts:i.pts, qty:i.qty })),
      subtotal: totals.subtotal, tax: totals.tax, total: totals.total,
      payment, change: payment-totals.total, pts: totals.pts,
    };

    /* Descontar stock del inventario si está cargado */
    if (InventoryStore.getAllRows().length) InventoryStore.decrementStock(sale.items);

    SalesStore.add(sale);
    const ticket = Logic.buildTicket(POSState.cart, totals, payment);
    POSState.cart = []; this._dom.payIn.value='';
    this._renderPOS();
    Toast.show(`Venta ${saleId} completada. Cambio: ${Logic.fmt(payment-totals.total)}`,'s');
    this._showTicketModal(ticket, sale);
    updateAlertBadge();
    AlertsRender.render();
  },

  /* ── Modal de ticket ── */
  _showTicketModal(ticket, sale) {
    const bg = document.createElement('div');
    bg.className='modal-bg';
    bg.innerHTML=`<div class="modal">
      <div class="modal-title">Venta completada</div>
      <div class="modal-sub">${sale.id} · ${Logic.fmtDate(sale.ts)} ${Logic.fmtTime(sale.ts)}</div>
      <pre class="ticket-pre">${Sanitize.esc(ticket)}</pre>

```
  <div class="modal-acts">
    <button class="btn btn-ghost" id="_mc">Cerrar</button>
    <button class="btn btn-primary" id="_mcp">Copiar ticket</button>
  </div>
</div>`;
document.body.appendChild(bg);
bg.querySelector('#_mc').addEventListener('click',()=>bg.remove());
bg.querySelector('#_mcp').addEventListener('click',()=>{ navigator.clipboard?.writeText(ticket).then(()=>Toast.show('Ticket copiado','s')); });
bg.addEventListener('click',e=>{ if(e.target===bg) bg.remove(); });
```

},

