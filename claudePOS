<script>
'use strict';

/* ══════════════════════════════════════
   CFG — Configuración centralizada
══════════════════════════════════════ */
const CFG = {
  TAX: 0.16,
  TOAST_MS: 2700,
  DEBOUNCE_MS: 180,
  LOCALE: 'es-MX',
  CURRENCY: 'MXN',
  /* Virtual scroll */
  ROW_H: 42,          // px por fila
  OVERSCAN: 8,        // filas extra renderizadas fuera del viewport
  /* ABC thresholds (impacto = precio × vendido) */
  ABC_A: 10000,
  ABC_B: 4000,
  LOW_STOCK: 5,
  /* Storage keys */
  SK_CART:   'propos_cart_v4',
  SK_SALES:  'propos_sales_v4',
  SK_INV:    'propos_inv_v4',
  /* Columnas esperadas en Excel (case-insensitive) */
  XL_COLS: {
    sku:         ['sku', 'codigo', 'code', 'id'],
    descripcion: ['descripcion', 'description', 'nombre', 'name', 'desc'],
    piezas:      ['piezas', 'stock', 'cantidad', 'qty', 'quantity', 'existencia'],
    precio:      ['precio', 'price', 'costo', 'cost', 'importe'],
    puntos:      ['puntos', 'points', 'pts', 'reward'],
    categoria:   ['categoria', 'category', 'cat', 'tipo', 'type'],
  },
};

/* ══════════════════════════════════════
   Storage — wrapper seguro de localStorage
══════════════════════════════════════ */
const Storage = {
  get(k, fb = null) { try { const r = localStorage.getItem(k); return r ? JSON.parse(r) : fb; } catch { return fb; } },
  set(k, v) { try { localStorage.setItem(k, JSON.stringify(v)); } catch(e) { console.warn('[POS storage]', e); } },
  del(k) { try { localStorage.removeItem(k); } catch { } },
};

/* ══════════════════════════════════════
   Sanitize — prevención de XSS / injection
   Sanitiza todo dato que proviene del Excel
   antes de insertarlo en el DOM o en el store.
══════════════════════════════════════ */
const Sanitize = {
  /* Escapa HTML entities */
  esc(s) {
    if (s == null) return '';
    const d = document.createElement('div');
    d.textContent = String(s);
    return d.innerHTML;
  },
  /* Limpia string: elimina caracteres de control, recorta espacios */
  str(s) {
    if (s == null) return '';
    return String(s)
      .replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g, '') // ctrl chars
      .replace(/[<>"'`]/g, c => ({'<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;','`':'&#96;'}[c]))
      .trim()
      .slice(0, 500); // max 500 chars
  },
  /* Parsea número de forma segura */
  num(v, fallback = 0) {
    const n = parseFloat(String(v).replace(/[^0-9.\-]/g, ''));
    return isNaN(n) ? fallback : n;
  },
  /* Parsea entero */
  int(v, fallback = 0) {
    const n = parseInt(String(v).replace(/[^0-9\-]/g, ''), 10);
    return isNaN(n) ? fallback : n;
  },
};

/* ══════════════════════════════════════
   ExcelParser — SheetJS async parser
   Diseño: Web Worker simulado con scheduler
   para no bloquear el main thread en archivos
   grandes. Indexa por SKU para O(1) lookup.
══════════════════════════════════════ */
const ExcelParser = {
  /**
   * Detecta qué columna del Excel corresponde a cada campo
   * usando aliases case-insensitive definidos en CFG.XL_COLS
   */
  _detectColumns(headers) {
    const hLow = headers.map(h => String(h).toLowerCase().trim());
    const map = {};
    for (const [field, aliases] of Object.entries(CFG.XL_COLS)) {
      const idx = hLow.findIndex(h => aliases.some(a => h.includes(a)));
      if (idx !== -1) map[field] = idx;
    }
    return map;
  },

  /**
   * Convierte una hoja XLSX en array de objetos validados.
   * Retorna { rows[], index{}, errors[], warnings[] }
   *
   * Procesamos en micro-batches usando queueMicrotask para
   * ceder el hilo entre chunks (simula comportamiento async
   * sin Web Workers, compatible con todos los navegadores).
   */
  async parseSheet(workbook, onProgress) {
    const sheetName = workbook.SheetNames[0];
    const ws = workbook.Sheets[sheetName];
    /* Convertir a array de arrays (AOA) — más rápido que to_json */
    const aoa = XLSX.utils.sheet_to_json(ws, { header: 1, defval: '' });

    if (!aoa.length) throw new Error('El archivo está vacío');

    /* Detectar fila de headers (busca la primera con >= 3 celdas con contenido) */
    let headerRow = 0;
    for (let i = 0; i < Math.min(5, aoa.length); i++) {
      const filled = aoa[i].filter(c => String(c).trim().length > 0).length;
      if (filled >= 3) { headerRow = i; break; }
    }

    const headers = aoa[headerRow].map(h => String(h).trim());
    const colMap = this._detectColumns(headers);

    /* Validar columnas requeridas */
    const required = ['sku', 'descripcion', 'piezas', 'precio'];
    const missing = required.filter(f => colMap[f] === undefined);
    if (missing.length) {
      throw new Error(`Columnas no encontradas: ${missing.join(', ')}. Revisa que tu Excel tenga las columnas correctas.`);
    }

    const rows = [];
    const index = {};    // SKU → row (O(1) lookup)
    const errors = [];
    const warnings = [];
    const seenSKUs = new Set();
    const dataRows = aoa.slice(headerRow + 1);
    const total = dataRows.length;

    /* Procesar en chunks de 200 para no bloquear UI */
    const CHUNK = 200;
    for (let i = 0; i < total; i += CHUNK) {
      const chunk = dataRows.slice(i, Math.min(i + CHUNK, total));
      for (const rawRow of chunk) {
        /* Saltar filas completamente vacías */
        if (rawRow.every(c => String(c).trim() === '')) continue;

        const rawSku = rawRow[colMap.sku];
        const sku = Sanitize.str(rawSku);

        /* Validar SKU */
        if (!sku) { errors.push(`Fila ${i + 1}: SKU vacío, fila omitida`); continue; }

        /* Detectar duplicados */
        if (seenSKUs.has(sku)) {
          warnings.push(`SKU duplicado: "${sku}" — se tomó la primera ocurrencia`);
          continue;
        }
        seenSKUs.add(sku);

        const row = {
          sku,
          descripcion: Sanitize.str(rawRow[colMap.descripcion] ?? ''),
          piezas:      Math.max(0, Sanitize.int(rawRow[colMap.piezas] ?? 0)),
          precio:      Math.max(0, Sanitize.num(rawRow[colMap.precio] ?? 0)),
          puntos:      colMap.puntos !== undefined ? Math.max(0, Sanitize.int(rawRow[colMap.puntos] ?? 0)) : 0,
          categoria:   colMap.categoria !== undefined ? Sanitize.str(rawRow[colMap.categoria] ?? '') : 'General',
          /* Metadatos internos — nunca se muestran como input raw */
          _modified:   false,
          _id:         sku,
        };

        /* Validar precio mínimo */
        if (row.precio <= 0) {
          warnings.push(`SKU "${sku}": precio 0 o negativo, se marcó como $0.00`);
        }

        rows.push(row);
        index[sku] = row;
      }

      /* Reportar progreso y ceder hilo */
      if (onProgress) onProgress(Math.round(((i + CHUNK) / total) * 100));
      await new Promise(r => setTimeout(r, 0)); // yield to browser
    }

    return { rows, index, errors, warnings, sheetName };
  },

  /**
   * Lee un File object y parsea con SheetJS.
   * Soporta .xlsx, .xls, .csv
   */
  async readFile(file, onProgress) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = async (e) => {
        try {
          onProgress?.(10);
          const data = new Uint8Array(e.target.result);
          /* SheetJS: leer con type:'array' para máxima compatibilidad */
          const wb = XLSX.read(data, {
            type: 'array',
            cellDates: true,
            /* Limitar filas para datasets extremadamente grandes */
            sheetRows: 10001,
          });
          onProgress?.(40);
          const result = await ExcelParser.parseSheet(wb, p => onProgress?.(40 + Math.round(p * 0.55)));
          onProgress?.(100);
          resolve(result);
        } catch (err) {
          reject(err);
        }
      };
      reader.onerror = () => reject(new Error('No se pudo leer el archivo'));
      reader.readAsArrayBuffer(file);
    });
  },

  /* Genera plantilla Excel descargable */
  downloadTemplate() {
    const headers = ['SKU', 'Descripcion', 'Piezas', 'Precio', 'Puntos', 'Categoria'];
    const sample = [
      ['P001', 'Producto Ejemplo 1', 50, 99.90, 10, 'Bebidas'],
      ['P002', 'Producto Ejemplo 2', 12, 145.00, 25, 'Alimentos'],
      ['P003', 'Producto Ejemplo 3', 3, 55.50, 5, 'Postres'],
    ];
    const ws = XLSX.utils.aoa_to_sheet([headers, ...sample]);
    /* Ancho de columnas */
    ws['!cols'] = [10,30,10,10,10,15].map(w => ({ wch: w }));
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Inventario');
    XLSX.writeFile(wb, 'plantilla_inventario.xlsx');
  },

  /* Exporta datos actuales a Excel */
  exportToExcel(rows) {
    const headers = ['SKU', 'Descripcion', 'Piezas', 'Precio', 'Puntos', 'Categoria'];
    const data = rows.map(r => [r.sku, r.descripcion, r.piezas, r.precio, r.puntos, r.categoria]);
    const ws = XLSX.utils.aoa_to_sheet([headers, ...data]);
    ws['!cols'] = [12, 35, 10, 12, 10, 16].map(w => ({ wch: w }));
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Inventario');
    XLSX.writeFile(wb, `inventario_${new Date().toISOString().slice(0,10)}.xlsx`);
  },
};

/* ══════════════════════════════════════
   VirtualScroll — renderizado eficiente
   Solo renderiza las filas visibles + overscan.
   Soporta 10,000+ filas sin degradación.
══════════════════════════════════════ */
const VirtualScroll = {
  _container: null,
  _spacer: null,
  _rows: [],
  _rowH: CFG.ROW_H,
  _overscan: CFG.OVERSCAN,
  _renderedRange: { start: 0, end: 0 },
  _rafId: null,
  _onRowClick: null,
  _editingRow: null,

  init(containerEl, spacerEl, onRowClick) {
    this._container = containerEl;
    this._spacer = spacerEl;
    this._onRowClick = onRowClick;

    /* Limpiar listener anterior si existe */
    this._container.onscroll = null;
    this._container.addEventListener('scroll', () => {
      /* rAF throttling para smooth scroll */
      if (this._rafId) return;
      this._rafId = requestAnimationFrame(() => {
        this._rafId = null;
        this._renderVisible();
      });
    }, { passive: true });
  },

  setRows(rows) {
    this._rows = rows;
    /* Guard: el spacer puede ser null si la vista inventario no está montada aún */
    if (!this._spacer || !this._container) return;
    /* Altura total del contenido virtual */
    this._spacer.style.height = (rows.length * this._rowH) + 'px';
    /* Reset scroll */
    this._container.scrollTop = 0;
    this._renderVisible();
  },

  _renderVisible() {
    if (!this._spacer || !this._container) return;
    if (!this._rows.length) {
      this._spacer.innerHTML = `<div style="text-align:center;padding:48px;color:var(--txt-3);font-size:.8rem">Sin resultados para los filtros aplicados</div>`;
      return;
    }
    const scrollTop = this._container.scrollTop;
    const viewH = this._container.clientHeight;

    const startIdx = Math.max(0, Math.floor(scrollTop / this._rowH) - this._overscan);
    const endIdx   = Math.min(this._rows.length - 1, Math.ceil((scrollTop + viewH) / this._rowH) + this._overscan);

    /* Evitar re-render si el rango no cambió */
    if (startIdx === this._renderedRange.start && endIdx === this._renderedRange.end) return;
    this._renderedRange = { start: startIdx, end: endIdx };

    /* Limpiar solo filas existentes (preservar spacer height) */
    const existing = this._spacer.querySelectorAll('.vrow');
    existing.forEach(el => el.remove());

    const frag = document.createDocumentFragment();
    for (let i = startIdx; i <= endIdx; i++) {
      const row = this._rows[i];
      const el = this._buildRow(row, i);
      frag.appendChild(el);
    }
    this._spacer.appendChild(frag);
  },

  _buildRow(row, idx) {
    const el = document.createElement('div');
    el.className = 'vrow';
    el.dataset.sku = row.sku;
    el.dataset.idx = idx;
    el.style.top = (idx * this._rowH) + 'px';
    el.style.height = this._rowH + 'px';

    /* Sanitize.esc ya fue aplicado al parsear — double-check en render */
    const stockCls = row.piezas === 0 ? 'sb-out' : row.piezas < CFG.LOW_STOCK ? 'sb-low' : 'sb-ok';
    const stockLbl = row.piezas === 0 ? 'Sin stock' : row.piezas < CFG.LOW_STOCK ? 'Stock bajo' : 'OK';
    const abcCls   = InventoryStore.getABC(row.sku);

    el.innerHTML = `
      <div class="vtd" style="color:var(--txt-3);font-size:.62rem">${idx + 1}</div>
      <div class="vtd vtd-sku">${Sanitize.esc(row.sku)}</div>
      <div class="vtd vtd-desc" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:block;line-height:${CFG.ROW_H}px">${Sanitize.esc(row.descripcion)}</div>
      <div class="vtd vtd-num">
        <span class="stock-badge ${stockCls}">${row.piezas} · ${stockLbl}</span>
      </div>
      <div class="vtd vtd-price">${Logic.fmt(row.precio)}</div>
      <div class="vtd vtd-pts">${row.puntos > 0 ? row.puntos + ' pts' : '<span style="color:var(--txt-3)">—</span>'}</div>
      <div class="vtd row-actions">
        <button class="ra-btn add" data-sku="${Sanitize.esc(row.sku)}" title="Agregar al carrito">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
        <button class="ra-btn edit" data-sku="${Sanitize.esc(row.sku)}" title="Editar fila">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </button>
        <span class="abc-chip abc-${abcCls}">${abcCls}</span>
      </div>`;

    /* Delegación de eventos en la fila */
    el.addEventListener('click', (e) => {
      const addBtn  = e.target.closest('.ra-btn.add');
      const editBtn = e.target.closest('.ra-btn.edit');
      if (addBtn) {
        e.stopPropagation();
        this._onRowClick?.('add', row);
      } else if (editBtn) {
        e.stopPropagation();
        this._startEdit(el, row, idx);
      }
    });

    return el;
  },

  /* Inline edit — edición directa en la celda */
  _startEdit(rowEl, row, idx) {
    /* Precio editable inline */
    const priceCell = rowEl.querySelectorAll('.vtd')[4];
    const piezasCell = rowEl.querySelectorAll('.vtd')[3];

    const priceInput = document.createElement('input');
    priceInput.className = 'cell-edit';
    priceInput.type = 'number';
    priceInput.value = row.precio;
    priceInput.min = '0';
    priceInput.style.width = '70px';

    const piezasInput = document.createElement('input');
    piezasInput.className = 'cell-edit';
    piezasInput.type = 'number';
    piezasInput.value = row.piezas;
    piezasInput.min = '0';
    piezasInput.style.width = '50px';

    priceCell.innerHTML  = '';
    priceCell.appendChild(priceInput);
    /* Reemplazar el badge de stock con el input */
    const badge = piezasCell.querySelector('.stock-badge');
    if (badge) { badge.style.display = 'none'; piezasCell.appendChild(piezasInput); }

    rowEl.classList.add('editing');
    priceInput.focus();

    const commit = () => {
      const newPrice  = Math.max(0, Sanitize.num(priceInput.value));
      const newPiezas = Math.max(0, Sanitize.int(piezasInput.value));
      InventoryStore.updateRow(row.sku, { precio: newPrice, piezas: newPiezas });
      Toast.show(`"${row.sku}" actualizado`, 's');
    };

    const keys = ['Enter', 'Tab', 'Escape'];
    [priceInput, piezasInput].forEach(inp => {
      inp.addEventListener('blur', () => setTimeout(() => { if (!rowEl.contains(document.activeElement)) commit(); }, 100));
      inp.addEventListener('keydown', e => { if (keys.includes(e.key)) { e.preventDefault(); commit(); } });
    });
  },

  refresh() { this._renderedRange = { start: -1, end: -1 }; this._renderVisible(); },
};

/* ══════════════════════════════════════
   InventoryStore — state del inventario
   Índice por SKU para O(1) lookups.
   Memoización de filtros con cache invalidation.
══════════════════════════════════════ */
const InventoryStore = {
  _rows: [],          // array maestro
  _index: {},         // SKU → row
  _sales: [],         // historial de ventas (para ABC)
  _filterCache: null, // caché de resultado filtrado
  _lastFilter: null,  // clave del último filtro (para invalidar)

  load(rows, index) {
    this._rows = rows;
    this._index = index;
    this._filterCache = null;
    Storage.set(CFG.SK_INV, rows);
    this._rebuildABC();
  },

  loadFromStorage() {
    const saved = Storage.get(CFG.SK_INV, null);
    if (saved && Array.isArray(saved) && saved.length) {
      this._rows = saved;
      this._index = {};
      saved.forEach(r => { this._index[r.sku] = r; });
      this._rebuildABC();
      return true;
    }
    return false;
  },

  getRow(sku) { return this._index[sku] ?? null; },

  updateRow(sku, patch) {
    const row = this._index[sku];
    if (!row) return;
    Object.assign(row, patch, { _modified: true });
    this._filterCache = null;
    Storage.set(CFG.SK_INV, this._rows);
    this._rebuildABC();
    VirtualScroll.refresh();
    AlertsRender.render();
    updateAlertBadge();
  },

  /* Filtrado memoizado — solo recalcula si los params cambian */
  filter(query, cat, stockFilter, abcFilter) {
    const key = `${query}|${cat}|${stockFilter}|${abcFilter}`;
    if (key === this._lastFilter && this._filterCache) return this._filterCache;

    const q = query.toLowerCase().trim();
    const result = this._rows.filter(r => {
      if (q && !r.sku.toLowerCase().includes(q) && !r.descripcion.toLowerCase().includes(q)) return false;
      if (cat && r.categoria !== cat) return false;
      if (stockFilter === 'ok'  && r.piezas < CFG.LOW_STOCK) return false;
      if (stockFilter === 'low' && (r.piezas === 0 || r.piezas >= CFG.LOW_STOCK)) return false;
      if (stockFilter === 'out' && r.piezas !== 0) return false;
      if (abcFilter && this._abc[r.sku] !== abcFilter) return false;
      return true;
    });

    this._lastFilter = key;
    this._filterCache = result;
    return result;
  },

  /* Categorías únicas */
  getCategories() { return [...new Set(this._rows.map(r => r.categoria).filter(Boolean))].sort(); },

  /* Valor total del inventario */
  getTotalValue() { return this._rows.reduce((a, r) => a + r.precio * r.piezas, 0); },

  /* Productos con stock bajo */
  getLowStock() { return this._rows.filter(r => r.piezas < CFG.LOW_STOCK); },

  /* Clasificación ABC */
  _abc: {},
  _rebuildABC() {
    const sales = SalesStore.getAll();
    this._abc = {};
    this._rows.forEach(r => {
      const sold = sales.reduce((a, s) => {
        return a + s.items.filter(i => i.sku === r.sku).reduce((b, i) => b + i.qty, 0);
      }, 0);
      const impact = r.precio * sold;
      this._abc[r.sku] = impact >= CFG.ABC_A ? 'A' : impact >= CFG.ABC_B ? 'B' : 'C';
    });
  },

  getABC(sku) { return this._abc[sku] ?? 'C'; },

  getAllRows() { return this._rows; },

  /* Decrementar stock tras una venta */
  decrementStock(items) {
    items.forEach(item => {
      const row = this._index[item.sku];
      if (row) row.piezas = Math.max(0, row.piezas - item.qty);
    });
    this._filterCache = null;
    Storage.set(CFG.SK_INV, this._rows);
  },
};

