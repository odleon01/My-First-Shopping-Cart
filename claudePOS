/* ── Cargar archivo Excel ── */
async _loadExcelFile(file) {
/* Validar tipo */
const allowed = [‘application/vnd.openxmlformats-officedocument.spreadsheetml.sheet’,‘application/vnd.ms-excel’,‘text/csv’];
const extOk = /.(xlsx|xls|csv)$/i.test(file.name);
if (!extOk) { Toast.show(‘Tipo de archivo no soportado. Usa .xlsx, .xls o .csv’,‘e’); return; }

```
const progress = document.getElementById('parse-progress');
const progBar  = document.getElementById('prog-bar');
const progLbl  = document.getElementById('prog-label');
progress.style.display = 'block';

try {
  const result = await ExcelParser.readFile(file, (pct) => {
    progBar.style.width = pct + '%';
    progLbl.textContent = pct < 100 ? `Procesando... ${pct}%` : 'Finalizando...';
  });

  /* Mostrar warnings sin bloquear */
  if (result.warnings.length) {
    console.warn('[POS Excel] Advertencias:', result.warnings);
    Toast.show(`${result.warnings.length} advertencia(s) al parsear. Revisa la consola.`,'w');
  }
  if (result.errors.length) {
    Toast.show(`${result.errors.length} fila(s) omitida(s) por errores de validación`,'w');
  }

  InventoryStore.load(result.rows, result.index);
  POSState.syncFromInventory();

  this._showInvLoaded();
  this._populateCatFilter();
  this._applyInvFilters();
  this._renderPOS();
  updateAlertBadge();
  AlertsRender.render();

  Toast.show(`${result.rows.length} productos cargados desde "${file.name}"`,'s');
} catch (err) {
  console.error('[POS Excel]', err);
  Toast.show(`Error: ${err.message}`,'e');
} finally {
  progress.style.display = 'none';
  progBar.style.width = '0%';
}
```

