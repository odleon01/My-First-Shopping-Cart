/* ── Teclado ── */
_bindKeyboard() {
document.addEventListener(‘keydown’, e => {
const { key, ctrlKey, target } = e;
const typing = target.tagName===‘INPUT’;

```
  if (ctrlKey && key==='d') { e.preventDefault(); if (POSState.cart.length) { POSState.cart=[]; this._dom.payIn.value=''; this._renderPOS(); Toast.show('Orden vaciada','i'); } return; }
  if (key==='/' && !typing) { e.preventDefault(); this._dom.search.focus(); return; }
  if (key==='Escape') { this._dom.search.value=''; POSState.search=''; POSState.hlIdx=-1; this._dom.search.blur(); this._renderPOS(); return; }

  if (!typing || target===this._dom.search) {
    const fp=this._kbFP; let idx=POSState.hlIdx;
    if (key==='ArrowDown') { e.preventDefault(); POSState.hlIdx=Math.min(idx+1,fp.length-1); this._renderPOS(); }
    else if (key==='ArrowUp') { e.preventDefault(); POSState.hlIdx=Math.max(idx-1,0); this._renderPOS(); }
    else if (key==='Enter' && idx>=0 && fp[idx]) { e.preventDefault(); this._addToCart(fp[idx].id); }
  }
});
