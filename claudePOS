<!DOCTYPE html>

<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>PROPOS v4 — POS + Gestión de Inventario</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet"/>
<!--
  SheetJS (xlsx) — CDN oficial permitido por CSP
  Usamos la build UMD completa para máxima compatibilidad Chromium
-->
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>

<style>
/* ═══════════════════════════════════════
   DESIGN TOKENS
═══════════════════════════════════════ */
:root {
  --bg-base:       #080b0f;
  --bg-surface:    #0f1218;
  --bg-elevated:   #151a23;
  --bg-overlay:    #1c2231;
  --bg-glass:      rgba(15,18,24,0.85);

  --border-1:      rgba(255,255,255,0.05);
  --border-2:      rgba(255,255,255,0.10);
  --border-3:      rgba(255,255,255,0.18);

  --accent:        #f0b429;
  --accent-lo:     rgba(240,180,41,0.08);
  --accent-mid:    rgba(240,180,41,0.18);
  --accent-glow:   rgba(240,180,41,0.28);

  --green:         #2dd4aa;
  --green-lo:      rgba(45,212,170,0.08);
  --red:           #f16d6d;
  --red-lo:        rgba(241,109,109,0.08);
  --blue:          #5ba8fb;
  --blue-lo:       rgba(91,168,251,0.08);
  --purple:        #a97cfb;
  --purple-lo:     rgba(169,124,251,0.08);
  --orange:        #fb8b3c;
  --orange-lo:     rgba(251,139,60,0.08);
  --cyan:          #22d3ee;
  --cyan-lo:       rgba(34,211,238,0.08);

  --txt-1:         #e8ecf4;
  --txt-2:         #7d899e;
  --txt-3:         #3a4558;

  --ff-display:    'Syne', sans-serif;
  --ff-mono:       'DM Mono', monospace;

  --r1: 5px; --r2: 9px; --r3: 14px; --r4: 20px;
  --ease: cubic-bezier(.4,0,.2,1);
  --t: all .16s var(--ease);
}

/* ═══════════════════════════════════════
   RESET
═══════════════════════════════════════ */
*,*::before,*::after { box-sizing:border-box; margin:0; padding:0 }
html { font-size:16px }
body {
  background: var(--bg-base);
  color: var(--txt-1);
  font-family: var(--ff-mono);
  height: 100vh;
  overflow: hidden;
  line-height: 1.55;
}
button { font-family:inherit; cursor:pointer; }
input, select { font-family:inherit; }
::-webkit-scrollbar { width:4px; height:4px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:var(--border-1); border-radius:99px; }
::-webkit-scrollbar-thumb:hover { background:var(--border-2); }

/* ═══════════════════════════════════════
   SHELL — grid 3-column layout
═══════════════════════════════════════ */
#shell {
  display: grid;
  grid-template-rows: 52px 1fr;
  grid-template-columns: 56px 1fr;
  height: 100vh;
}

/* ───────── TOPBAR ───────── */
.topbar {
  grid-column: 1/-1;
  display: flex;
  align-items: center;
  gap: 18px;
  padding: 0 20px;
  background: var(--bg-surface);
  border-bottom: 1px solid var(--border-1);
  z-index: 300;
}
.brand { display:flex; align-items:center; gap:8px; text-decoration:none; flex-shrink:0; }
.brand-logo {
  width:28px; height:28px;
  background:var(--accent);
  border-radius:var(--r1);
  display:flex; align-items:center; justify-content:center;
}
.brand-logo svg { width:14px; height:14px; fill:#000; }
.brand-name {
  font-family:var(--ff-display);
  font-weight:800; font-size:.95rem;
  letter-spacing:-.03em;
}
.brand-name em { color:var(--accent); font-style:normal; }

/* universal search */
.topbar-search {
  flex:1; max-width:360px; position:relative;
}
.topbar-search svg {
  position:absolute; left:11px; top:50%;
  transform:translateY(-50%);
  color:var(--txt-3); pointer-events:none;
  transition:var(--t);
}
#g-search {
  width:100%;
  padding:7px 11px 7px 34px;
  background:var(--bg-elevated);
  border:1px solid var(--border-1);
  border-radius:var(--r2);
  color:var(--txt-1);
  font-size:.78rem;
  outline:none;
  transition:var(--t);
}
#g-search::placeholder { color:var(--txt-3); }
#g-search:focus {
  border-color:var(--accent);
  box-shadow: 0 0 0 3px var(--accent-lo);
}
#g-search:focus ~ svg { color:var(--accent); }

.topbar-right { margin-left:auto; display:flex; align-items:center; gap:10px; }
.t-clock { font-size:.72rem; color:var(--txt-3); letter-spacing:.05em; }
.t-badge {
  display:flex; align-items:center; gap:4px;
  padding:2px 9px; border-radius:99px;
  background:var(--green-lo);
  border:1px solid rgba(45,212,170,.18);
  font-size:.64rem; color:var(--green); letter-spacing:.07em;
}
.t-badge::before {
  content:''; width:5px; height:5px; border-radius:50%;
  background:var(--green); animation:pulse 2s infinite;
}
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.45;transform:scale(.8)} }

/* version pill */
.v-pill {
  font-size:.62rem; padding:2px 8px; border-radius:99px;
  background:var(--accent-lo); color:var(--accent);
  border:1px solid var(--accent-mid);
  letter-spacing:.05em;
}

/* ───────── SIDEBAR ───────── */
.sidebar {
  background:var(--bg-surface);
  border-right:1px solid var(--border-1);
  display:flex; flex-direction:column; align-items:center;
  padding:12px 0; gap:4px;
}
.nav-item {
  width:40px; height:40px;
  border-radius:var(--r2);
  border:none; background:transparent;
  color:var(--txt-3);
  display:flex; align-items:center; justify-content:center;
  transition:var(--t); position:relative; cursor:pointer;
}
.nav-item svg { width:17px; height:17px; }
.nav-item:hover { background:var(--bg-elevated); color:var(--txt-2); }
.nav-item.active { background:var(--accent-lo); color:var(--accent); }
.nav-item.active::before {
  content:''; position:absolute;
  left:0; top:50%; transform:translateY(-50%);
  width:3px; height:22px;
  background:var(--accent); border-radius:0 3px 3px 0;
}
.nav-sep { width:22px; height:1px; background:var(--border-1); margin:4px 0; }
.nav-badge {
  position:absolute; top:5px; right:5px;
  min-width:13px; height:13px; border-radius:99px;
  background:var(--red); color:#fff;
  font-size:.52rem; font-weight:700;
  display:flex; align-items:center; justify-content:center;
  padding:0 2px;
}
/* tooltip on hover */
.nav-item[data-tip]::after {
  content: attr(data-tip);
  position:absolute; left:calc(100% + 10px); top:50%;
  transform:translateY(-50%);
  background:var(--bg-overlay);
  border:1px solid var(--border-2);
  color:var(--txt-1);
  font-size:.68rem; font-family:var(--ff-mono);
  padding:3px 9px; border-radius:var(--r1);
  white-space:nowrap; opacity:0; pointer-events:none;
  transition:opacity .12s; z-index:400;
}
.nav-item[data-tip]:hover::after { opacity:1; }

/* ═══════════════════════════════════════
   VIEWS
═══════════════════════════════════════ */
.main { overflow:hidden; position:relative; }
.view { display:none; height:100%; }
.view.active { display:flex; }

/* ══════════════════════════════════════
   VIEW: POS  (layout idéntico al original, heredado)
══════════════════════════════════════ */
#v-pos { flex-direction:row; }

.products-panel {
  flex:1; display:flex; flex-direction:column; overflow:hidden;
  border-right:1px solid var(--border-1);
}
.panel-top {
  padding:14px 22px 12px;
  display:flex; align-items:center; justify-content:space-between; gap:12px;
  border-bottom:1px solid var(--border-1);
  background:var(--bg-surface); flex-shrink:0;
}
.panel-title {
  font-family:var(--ff-display);
  font-weight:700; font-size:.9rem; letter-spacing:-.02em;
}
.panel-count { font-size:.68rem; color:var(--txt-3); margin-top:1px; }
.filter-bar { display:flex; gap:5px; overflow-x:auto; scrollbar-width:none; }
.filter-bar::-webkit-scrollbar { display:none; }
.f-btn {
  padding:4px 11px; border-radius:99px;
  border:1px solid var(--border-1);
  background:transparent; color:var(--txt-2);
  font-family:var(--ff-mono); font-size:.7rem;
  cursor:pointer; white-space:nowrap; transition:var(--t);
}
.f-btn:hover { border-color:var(--border-2); color:var(--txt-1); background:var(--bg-overlay); }
.f-btn.active { background:var(--accent); border-color:var(--accent); color:#000; font-weight:500; }

.products-body { flex:1; overflow-y:auto; padding:18px 22px; }
.products-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(168px,1fr));
  gap:10px;
}

/* Product card */
.pc {
  background:var(--bg-surface);
  border:1px solid var(--border-1);
  border-radius:var(--r3);
  padding:16px; cursor:pointer;
  transition:var(--t); position:relative;
  overflow:hidden; display:flex; flex-direction:column; gap:9px;
  animation:fadeUp .2s ease both;
}
.pc::before {
  content:''; position:absolute; inset:0;
  background:var(--accent-lo); opacity:0;
  transition:var(--t); border-radius:inherit;
}
.pc:hover { border-color:var(--border-2); transform:translateY(-2px); }
.pc:hover::before { opacity:1; }
.pc.hl { border-color:var(--accent); box-shadow:0 0 0 2px var(--accent-lo),0 0 20px var(--accent-glow); }
.pc.hl::before { opacity:1; }
.pc-icon { font-size:1.2rem; z-index:1; position:relative; }
.pc-name {
  font-family:var(--ff-display); font-weight:600; font-size:.82rem;
  color:var(--txt-1); line-height:1.25; z-index:1; position:relative;
}
.pc-sku { font-size:.62rem; color:var(--txt-3); letter-spacing:.05em; z-index:1; position:relative; }
.pc-foot {
  display:flex; align-items:center; justify-content:space-between;
  z-index:1; position:relative; margin-top:auto;
}
.pc-price { font-family:var(--ff-mono); font-size:.92rem; color:var(--accent); }
.pc-add {
  width:24px; height:24px; border-radius:50%;
  border:1px solid var(--border-2);
  background:var(--bg-elevated); color:var(--txt-2);
  display:flex; align-items:center; justify-content:center;
  transition:var(--t);
}
.pc-add:hover { background:var(--accent); border-color:var(--accent); color:#000; transform:scale(1.1); }
.pc-stock {
  position:absolute; top:9px; right:9px;
  font-size:.58rem; color:var(--txt-3); z-index:1;
}
.pc-stock.low { color:var(--red); }
.pc-pts {
  position:absolute; top:9px; left:9px;
  font-size:.58rem; color:var(--accent); z-index:1;
  background:var(--accent-lo); padding:1px 5px; border-radius:3px;
}
.empty-grid { grid-column:1/-1; text-align:center; padding:50px 0; color:var(--txt-3); }
.empty-title { font-family:var(--ff-display); font-weight:600; font-size:.92rem; color:var(--txt-2); margin-bottom:4px; }

/* Cart */
.cart-panel {
  width:350px; display:flex; flex-direction:column;
  background:var(--bg-surface); flex-shrink:0;
}
.cart-head { padding:14px 20px 11px; border-bottom:1px solid var(--border-1); flex-shrink:0; }
.cart-title {
  font-family:var(--ff-display); font-weight:700; font-size:.9rem;
  display:flex; align-items:center; justify-content:space-between;
}
.c-counter {
  min-width:19px; height:19px; background:var(--accent); color:#000;
  border-radius:99px; font-size:.64rem; font-weight:700;
  display:inline-flex; align-items:center; justify-content:center; padding:0 4px;
  transition:var(--t);
}
.c-counter.bump { animation:bump .25s ease; }
@keyframes bump { 0%{transform:scale(1)} 50%{transform:scale(1.45)} 100%{transform:scale(1)} }

.cart-list { flex:1; overflow-y:auto; padding:10px 18px; display:flex; flex-direction:column; gap:7px; }
.cart-empty {
  flex:1; display:flex; flex-direction:column; align-items:center;
  justify-content:center; color:var(--txt-3); text-align:center; padding:24px;
  gap:8px;
}
.cart-item {
  display:grid; grid-template-columns:1fr auto; grid-template-rows:auto auto;
  gap:3px 9px; align-items:center;
  background:var(--bg-elevated); border:1px solid var(--border-1);
  border-radius:var(--r2); padding:9px 11px;
  transition:var(--t); animation:slideIn .17s ease both;
}
.cart-item:hover { border-color:var(--border-2); }
.ci-name { font-family:var(--ff-display); font-weight:600; font-size:.78rem; grid-column:1; grid-row:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.ci-sub { font-size:.7rem; color:var(--txt-2); grid-column:1; grid-row:2; }
.ci-pts { font-size:.62rem; color:var(--accent); }
.ci-ctrl { display:flex; align-items:center; gap:4px; grid-column:2; grid-row:1/3; }
.qb {
  width:22px; height:22px; border-radius:var(--r1);
  border:1px solid var(--border-1);
  background:var(--bg-overlay); color:var(--txt-2);
  display:flex; align-items:center; justify-content:center; font-size:.8rem;
  transition:var(--t);
}
.qb:hover { border-color:var(--border-2); }
.qb.minus:hover { border-color:var(--red); color:var(--red); }
.qb.plus:hover { border-color:var(--green); color:var(--green); }
.qb.rm:hover { border-color:var(--red); background:var(--red-lo); color:var(--red); }
.qi { font-family:var(--ff-mono); font-size:.78rem; font-weight:500; min-width:18px; text-align:center; }

/* order summary */
.order-sum {
  padding:14px 18px; border-top:1px solid var(--border-1);
  flex-shrink:0; display:flex; flex-direction:column; gap:7px;
}
.sum-row { display:flex; justify-content:space-between; align-items:center; font-size:.74rem; }
.sum-lbl { color:var(--txt-2); }
.sum-v { font-family:var(--ff-mono); }
.sum-row.tot { padding-top:9px; border-top:1px solid var(--border-1); }
.sum-row.tot .sum-lbl { font-family:var(--ff-display); font-weight:700; font-size:.88rem; color:var(--txt-1); }
.sum-row.tot .sum-v { font-size:1.25rem; color:var(--accent); letter-spacing:-.03em; }
.pts-row { display:flex; justify-content:space-between; align-items:center; padding:5px 10px; background:var(--purple-lo); border:1px solid rgba(169,124,251,.15); border-radius:var(--r1); font-size:.72rem; }
.pts-lbl { color:var(--purple); display:flex; align-items:center; gap:4px; }
.pts-v { font-family:var(--ff-mono); color:var(--purple); }
.pay-sect { display:flex; flex-direction:column; gap:5px; margin-top:2px; }
.pay-sect label { font-size:.64rem; color:var(--txt-3); letter-spacing:.05em; text-transform:uppercase; }
.in-group { display:flex; align-items:center; background:var(--bg-elevated); border:1px solid var(--border-1); border-radius:var(--r2); overflow:hidden; transition:var(--t); }
.in-group:focus-within { border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-lo); }
.in-pfx { padding:0 9px; color:var(--txt-3); font-size:.82rem; border-right:1px solid var(--border-1); align-self:stretch; display:flex; align-items:center; background:var(--bg-overlay); }
#pay-in { flex:1; padding:8px 11px; background:transparent; border:none; outline:none; color:var(--txt-1); font-size:.88rem; }
#pay-in::placeholder { color:var(--txt-3); }
.chg-row { display:flex; justify-content:space-between; align-items:center; padding:6px 9px; background:var(--green-lo); border:1px solid rgba(45,212,170,.15); border-radius:var(--r1); font-size:.74rem; transition:var(--t); }
.chg-row.neg { background:var(--red-lo); border-color:rgba(241,109,109,.15); }
.chg-row.neg span { color:var(--red) !important; }
.chg-lbl { color:var(--green); } .chg-v { font-family:var(--ff-mono); color:var(--green); font-size:.88rem; }
.act-bar { display:grid; grid-template-columns:auto 1fr; gap:7px; }
.btn {
  padding:9px 16px; border-radius:var(--r2); border:none;
  font-family:var(--ff-display); font-weight:700; font-size:.8rem;
  letter-spacing:.02em; transition:var(--t);
  display:flex; align-items:center; justify-content:center; gap:6px;
}
.btn:active { transform:scale(.97); }
.btn-ghost { background:var(--bg-elevated); color:var(--txt-2); border:1px solid var(--border-1); }
.btn-ghost:hover { background:var(--red-lo); border-color:rgba(241,109,109,.25); color:var(--red); }
.btn-primary { background:var(--accent); color:#000; }
.btn-primary:hover { background:#f5c842; box-shadow:0 0 20px var(--accent-glow); transform:translateY(-1px); }
.btn-primary:disabled { opacity:.35; cursor:not-allowed; transform:none; box-shadow:none; }
.btn-outline { background:transparent; color:var(--txt-2); border:1px solid var(--border-2); }
.btn-outline:hover { background:var(--bg-elevated); color:var(--txt-1); }
.btn-blue { background:var(--blue-lo); color:var(--blue); border:1px solid rgba(91,168,251,.2); }
.btn-blue:hover { background:var(--blue); color:#000; }
.btn-green { background:var(--green-lo); color:var(--green); border:1px solid rgba(45,212,170,.2); }
.btn-green:hover { background:var(--green); color:#000; }

.kbd-hints { font-size:.6rem; color:var(--txt-3); display:flex; align-items:center; gap:5px; padding-top:5px; border-top:1px solid var(--border-1); flex-wrap:wrap; }
kbd { display:inline-flex; align-items:center; padding:1px 4px; background:var(--bg-overlay); border:1px solid var(--border-2); border-radius:3px; font-family:var(--ff-mono); font-size:.6rem; color:var(--txt-2); }


/* ══════════════════════════════════════
   VIEW: INVENTORY / EXCEL MODULE
══════════════════════════════════════ */
#v-inventory { flex-direction:column; overflow:hidden; }

.inv-shell { flex:1; display:flex; flex-direction:column; overflow:hidden; }

/* ── Upload Zone ── */
.upload-zone {
  flex:1; display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  padding:40px;
}
.drop-area {
  width:100%; max-width:560px;
  border:2px dashed var(--border-2);
  border-radius:var(--r4);
  padding:48px 32px;
  text-align:center;
  transition:var(--t);
  cursor:pointer;
  background:var(--bg-elevated);
  position:relative;
}
.drop-area:hover, .drop-area.drag-over {
  border-color:var(--accent);
  background:var(--accent-lo);
  box-shadow:0 0 40px var(--accent-glow);
}
.drop-icon { font-size:3rem; margin-bottom:16px; filter:grayscale(1) opacity(.5); transition:var(--t); }
.drop-area:hover .drop-icon { filter:none; }
.drop-title { font-family:var(--ff-display); font-weight:700; font-size:1.1rem; margin-bottom:6px; }
.drop-sub { font-size:.78rem; color:var(--txt-2); margin-bottom:20px; line-height:1.7; }
.drop-cols {
  display:flex; justify-content:center; gap:8px; flex-wrap:wrap; margin-bottom:20px;
}
.col-tag {
  padding:3px 9px; border-radius:99px;
  font-size:.65rem; font-weight:500; letter-spacing:.04em;
  border:1px solid;
}
.col-tag.required { color:var(--accent); border-color:var(--accent-mid); background:var(--accent-lo); }
.col-tag.optional { color:var(--txt-2); border-color:var(--border-1); background:var(--bg-overlay); }
#file-input { display:none; }

/* Progress */
.parse-progress { margin-top:20px; width:100%; max-width:400px; }
.prog-bar-wrap { height:4px; background:var(--bg-overlay); border-radius:99px; overflow:hidden; margin-top:8px; }
.prog-bar { height:100%; background:var(--accent); border-radius:99px; transition:width .3s ease; }
.prog-label { font-size:.72rem; color:var(--txt-2); text-align:center; }

/* Template download */
.tpl-section { margin-top:24px; }
.tpl-label { font-size:.7rem; color:var(--txt-3); margin-bottom:8px; text-align:center; }


/* ── Loaded State — Table ── */
.inv-loaded { flex:1; display:flex; flex-direction:column; overflow:hidden; }

.inv-toolbar {
  padding:12px 22px; display:flex; align-items:center; gap:10px;
  border-bottom:1px solid var(--border-1);
  background:var(--bg-surface); flex-shrink:0; flex-wrap:wrap;
}
.inv-search-wrap { position:relative; flex:1; min-width:200px; max-width:340px; }
.inv-search-wrap svg { position:absolute; left:10px; top:50%; transform:translateY(-50%); color:var(--txt-3); pointer-events:none; }
#inv-search {
  width:100%; padding:7px 10px 7px 32px;
  background:var(--bg-elevated);
  border:1px solid var(--border-1);
  border-radius:var(--r2);
  color:var(--txt-1); font-size:.76rem; outline:none; transition:var(--t);
}
#inv-search::placeholder { color:var(--txt-3); }
#inv-search:focus { border-color:var(--accent); box-shadow:0 0 0 3px var(--accent-lo); }

.inv-filters { display:flex; gap:6px; align-items:center; }
