const Router = (() => {
  const titles = {
    'pos':'Punto de Venta',
    'inventario':'Inventario',
    'compras':'Compras',
    'dashboard-ventas':'Dashboard · Ventas',
    'dashboard-inventario':'Dashboard · Inventario',
    'alertas':'Centro de Alertas',
    'usuarios':'Administración de Usuarios',
    'suscripciones':'Suscripción'
  };
  const renderers = {
    'pos': renderPOS,
    'inventario': renderInventario,
    'compras': renderCompras,
    'dashboard-ventas': renderDashboardVentas,
    'dashboard-inventario': renderDashboardInventario,
    'alertas': renderAlertas,
    'usuarios': renderUsuarios,
    'suscripciones': renderSuscripciones
  };
  function go(route) {
    Store.set('ui.modulo', route);
    document.querySelectorAll('.nav-item').forEach(el => {
      el.classList.toggle('active', el.dataset.route === route);
    });
    const bc = document.getElementById('breadcrumb-module');
    if (bc) bc.textContent = titles[route] || route;
    const mc = document.getElementById('main-content');
    mc.innerHTML = '';
    const fn = renderers[route];
    if (fn) fn(mc);
    else mc.innerHTML = `<div class="empty-state"><div class="empty-icon">🚧</div><p>Módulo en construcción</p></div>`;
  }
  return { go };
})();

