function guardarNuevoProducto() {
  const nombre = document.getElementById('np-nombre')?.value.trim();
  const sku = document.getElementById('np-sku')?.value.trim();
  const precio = parseFloat(document.getElementById('np-precio')?.value);
  const costo  = parseFloat(document.getElementById('np-costo')?.value);
  if (!nombre) { Toast.show('El nombre es requerido', 'error'); return; }
  if (!sku)    { Toast.show('El SKU es requerido', 'error'); return; }
  if (DB.productos.find(p=>p.sku===sku)) { Toast.show('El SKU ya existe', 'error'); return; }
  if (isNaN(precio) || precio <= 0) { Toast.show('Precio de venta inválido', 'error'); return; }
  DB.productos.push({ id:uid(), nombre, sku, cat:document.getElementById('np-cat')?.value||'Otros', precio, costo:isNaN(costo)?0:costo,
    stock:parseInt(document.getElementById('np-stock')?.value)||0,
    stockMin:parseInt(document.getElementById('np-stockmin')?.value)||10, activo:true });
  Modal.close();
  Toast.show(`Producto "${nombre}" creado exitosamente`, 'success');
  applyInvFilter();
}

