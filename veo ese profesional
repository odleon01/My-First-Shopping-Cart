const Store = (() => {
  const state = {
    pos: {
      turnoActivo: { id:'T-001', fondoInicial:500, hora:'08:00', cajero:'Carlos Admin' },
      carritoActivo: { id: uid(), lineas:[], cliente:null, tipoDoc:'ticket',
                       subtotal:0, descuento:0, impuestos:0, total:0, estado:'vacio' },
      metodoPago: [],
      ventaActual: null
    },
    alertas: { lista: [], noLeidas: 3 },
    ui: { modulo: 'pos', cargando: false }
  };
  const subs = {};
  function get(path) {
    return path.split('.').reduce((o,k) => o?.[k], state);
  }
  function set(path, val) {
    const keys = path.split('.');
    let obj = state;
    for (let i = 0; i < keys.length - 1; i++) obj = obj[keys[i]];
    obj[keys[keys.length-1]] = val;
    (subs[path]||[]).forEach(cb => { try { cb(val); } catch(e){} });
  }
  function sub(path, cb) {
    if (!subs[path]) subs[path] = [];
    subs[path].push(cb);
  }
  return { get, set, sub };
})();

/* ═══════════════════════════════════════════════════════════════
   EVENT BUS
═══════════════════════════════════════════════════════════════ */
const Bus = (() => {
  const handlers = {};
  function on(ev, fn) {
    if (!handlers[ev]) handlers[ev] = [];
    handlers[ev].push(fn);
  }
  function emit(ev, data) {
    (handlers[ev]||[]).forEach(fn => { try { fn(data); } catch(e){ console.error(e); } });
  }
  return { on, emit };
})();

