function renderSuscripciones(container) {
  const plans = [
    { nombre:'Starter', precio:499, usuarios:3, terminales:1, almacenes:1, features:['POS básico','Inventario simple','Dashboard esencial','Soporte por email'], current:false },
    { nombre:'Business', precio:999, usuarios:10, terminales:3, almacenes:2, features:['POS completo + fidelización','Inventario avanzado','Dashboards + exportación','Compras y CxP','Soporte prioritario'], current:true },
    { nombre:'Enterprise', precio:2499, usuarios:null, terminales:null, almacenes:null, features:['Todo Business +','Multi-sucursal','API integración','Módulo contable','Soporte dedicado 24/7'], current:false },
  ];
  const uso = { usuarios:{ actual:5, max:10 }, terminales:{ actual:2, max:3 }, almacenes:{ actual:1, max:2 }, transacciones:{ actual:1284, max:5000 } };
  container.innerHTML = `
    <div class="page-header">
      <div><div class="page-title">Suscripción</div><div class="page-subtitle">Plan Business · Renovación: 14 Feb 2024</div></div>
    </div>
    <div class="grid-3" style="margin-bottom:24px;">
      ${plans.map(p=>`
        <div class="plan-card ${p.current?'current':''}">
          <div class="plan-name">${p.nombre}</div>
          <div class="plan-price">${fmt(p.precio)}<span>/mes</span></div>
          <div class="text-xs text-dim" style="margin-bottom:12px;">
            ${p.usuarios?`${p.usuarios} usuarios · ${p.terminales} terminales`:'Ilimitado'}
          </div>
          <div class="plan-features">
            ${p.features.map(f=>`<div class="plan-feature">${f}</div>`).join('')}
          </div>
          ${p.current ? '<div style="margin-top:16px;"><span class="badge badge-green">Plan actual</span></div>' :
            `<button class="btn w-full" style="margin-top:16px;">${p.nombre==='Starter'?'Cambiar a Starter':'⬆️ Actualizar'}</button>`}
        </div>`).join('')}
    </div>
    <div class="card">
      <div class="card-header"><div class="card-title">Uso del Plan Business</div></div>
      <div class="grid-2">
        ${Object.entries(uso).map(([k,v])=>{
          const labels = { usuarios:'Usuarios activos', terminales:'Terminales POS', almacenes:'Almacenes', transacciones:'Transacciones del mes' };
          const pct = v.max ? Math.min((v.actual/v.max)*100, 100) : 0;
          const isHigh = pct > 80;
          return `<div style="margin-bottom:8px;">
            <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
              <span class="text-sm text-dim">${labels[k]}</span>
              <span class="td-mono text-sm">${v.actual} / ${v.max||'∞'}</span>
            </div>
            <div class="usage-bar"><div class="usage-fill ${isHigh?'high':''}" style="width:${pct}%"></div></div>
          </div>`;
        }).join('')}
      </div>
    </div>
    <div class="card" style="margin-top:16px;">
      <div class="card-header"><div class="card-title">Historial de Facturación</div></div>
      <table><thead><tr><th>Período</th><th>Plan</th><th>Monto</th><th>Estado</th><th></th></tr></thead>
        <tbody>
          ${[['Ene 2024','Business'],['Dic 2023','Business'],['Nov 2023','Starter']].map((r,i)=>`<tr>
            <td class="td-mono text-sm">${r[0]}</td>
            <td>${r[1]}</td>
            <td class="td-mono">${r[1]==='Business'?'$999.00':'$499.00'}</td>
            <td><span class="badge badge-green">Pagado</span></td>
            <td><button class="btn btn-sm btn-ghost">📄 Descargar</button></td>
          </tr>`).join('')}
        </tbody>
      </table>
    </div>`;
}

