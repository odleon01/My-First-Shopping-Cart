        <select class="input" style="width:130px;" onchange="filterInvCat(this.value)" id="inv-cat-sel">
          ${DB.categorias.map(c => `<option value="${c}">${c}</option>`).join('')}
        </select>
        <select class="input" style="width:140px;" onchange="filterInvStock(this.value)" id="inv-stock-sel">
