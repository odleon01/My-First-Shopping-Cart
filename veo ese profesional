function renderCartTable() {
  const c = getCarrito();
  if (c.lineas.length === 0) return `
    <div class="cart-empty">
      <div class="empty-icon">🛒</div>
      <p>Carrito vacío — selecciona productos</p>
    </div>`;
  return `
    <table class="cart-table">
      <thead><tr>
        <th>Producto</th><th>Cant.</th><th>Precio</th><th>Subtotal</th><th></th>
      </tr></thead>
      <tbody>
        ${c.lineas.map(l => `
          <tr>
            <td>
              <div style="font-weight:600;font-size:13px;">${l.nombre}</div>
              <div style="font-size:10px;color:var(--text3);font-family:var(--font-mono);">${l.sku}</div>
            </td>
            <td>
              <input class="cart-qty-input" type="number" min="1" value="${l.qty}"
                onchange="updateQty('${l.id}',this.value)" />
            </td>
            <td class="td-mono">${fmt(l.precio)}</td>
            <td class="td-mono text-amber">${fmt(l.precio * l.qty)}</td>
            <td><button class="cart-del-btn" onclick="removeFromCart('${l.id}')">✕</button></td>
