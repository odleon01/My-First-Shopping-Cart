function previewAjuste(prodId) {
  const p = DB.productos.find(x => x.id === prodId);
  const tipo = document.getElementById('adj-tipo')?.value;
  const qty = parseInt(document.getElementById('adj-qty')?.value) || 0;
  const prev = document.getElementById('adj-preview');
  if (!prev || qty <= 0) return;
  const result = tipo === 'incremento' ? p.stock + qty : Math.max(p.stock - qty, 0);
  const color = result === 0 ? 'var(--red)' : result < p.stockMin ? 'var(--orange)' : 'var(--green)';
  prev.innerHTML = `Stock actual: <strong>${p.stock}</strong> → Stock resultante: <strong style="color:${color};font-size:15px;">${result}</strong> uds`;
}

async function confirmarAjuste(prodId) {
  const p = DB.productos.find(x => x.id === prodId);
  const tipo = document.getElementById('adj-tipo')?.value;
  const qty = parseInt(document.getElementById('adj-qty')?.value);
  const motivo = document.getElementById('adj-motivo')?.value;
  if (!qty || qty <= 0) { Toast.show('Ingresa una cantidad válida', 'error'); return; }
  if (tipo === 'decremento' && qty > p.stock) { Toast.show('No puedes reducir más del stock actual', 'error'); return; }
  Modal.close();
  await Loading.wrap(() => new Promise(r => setTimeout(r, 600)));
  const prev = p.stock;
  p.stock = tipo === 'incremento' ? p.stock + qty : Math.max(p.stock - qty, 0);
  DB.movimientos.unshift({ id: uid(), fecha: new Date().toLocaleString('es-MX'), tipo:'ajuste', producto:p.nombre, cant: tipo==='incremento'?qty:-qty, saldo:p.stock, origen:`Ajuste — ${motivo}` });
  Toast.show(`Ajuste aplicado: ${p.nombre} ${prev} → ${p.stock} uds`, 'success');
  // Refresh
  applyInvFilter();
  // Alert if now critical
  if (p.stock === 0) {
    DB.alertas.unshift({ id:uid(), tipo:'inventario', prioridad:'critica', msg:`Sin existencia: ${p.nombre}`, meta:'Inventario · ahora', icono:'📦', leida:false, atendida:false });
    Store.set('alertas.noLeidas', Store.get('alertas.noLeidas') + 1);
    updateAlertBadge();
  }
}

