function renderAlertas(container) {
  const alertas = Store.get('alertas.lista');
  const noLeidas = alertas.filter(a=>!a.leida).length;
  container.innerHTML = `
    <div class="page-header">
      <div>
        <div class="page-title">Centro de Alertas</div>
        <div class="page-subtitle">${noLeidas} alerta(s) sin leer</div>
      </div>
      <div style="display:flex;gap:8px;">
        <button class="btn btn-ghost btn-sm" onclick="marcarTodasLeidas()">✓ Marcar todas como leídas</button>
        <select class="input" style="width:150px;" onchange="filterAlertas(this.value)" id="alerta-filter">
          <option value="todas">Todas</option>
          <option value="critica">Críticas</option>
          <option value="advertencia">Advertencias</option>
          <option value="info">Informativas</option>
          <option value="no_leidas">No leídas</option>
        </select>
      </div>
    </div>
    <div class="table-wrap">
      <div id="alertas-list">${renderAlertasList(alertas)}</div>
    </div>`;
}

function renderAlertasList(alertas) {
  if (alertas.length === 0) return `<div class="empty-state"><div class="empty-icon">🔔</div><p>Sin alertas</p></div>`;
  return alertas.map(a => `
    <div class="alert-item ${a.leida?'':'unread'}" id="alert-${a.id}">
      ${a.leida ? '' : '<div class="unread-dot"></div>'}
      <div class="alert-bar ${a.prioridad}"></div>
      <div class="alert-icon">${a.icono}</div>
      <div class="alert-body">
        <div class="alert-msg">${a.msg}</div>
        <div class="alert-meta">${a.prioridad.toUpperCase()} · ${a.tipo.toUpperCase()} · ${a.meta}</div>
      </div>
      <div class="alert-actions">
        ${!a.leida ? `<button class="btn btn-sm btn-ghost" onclick="marcarLeida('${a.id}')">Leída</button>` : ''}
        ${!a.atendida ? `<button class="btn btn-sm btn-success" onclick="atenderAlerta('${a.id}')">✓ Atender</button>` : `<span class="badge badge-gray">Atendida</span>`}
      </div>
    </div>`).join('');
}

function filterAlertas(tipo) {
  let lista = Store.get('alertas.lista');
  if (tipo === 'critica') lista = lista.filter(a=>a.prioridad==='critica');
  else if (tipo === 'advertencia') lista = lista.filter(a=>a.prioridad==='advertencia');
  else if (tipo === 'info') lista = lista.filter(a=>a.prioridad==='info');
  else if (tipo === 'no_leidas') lista = lista.filter(a=>!a.leida);
  document.getElementById('alertas-list').innerHTML = renderAlertasList(lista);
}

function marcarLeida(id) {
  const lista = Store.get('alertas.lista');
  const a = lista.find(x=>x.id===id);
  if (a) a.leida = true;
  Store.set('alertas.lista', lista);
  Store.set('alertas.noLeidas', Math.max(Store.get('alertas.noLeidas')-1, 0));
  updateAlertBadge();
  const el = document.getElementById('alert-'+id);
  if (el) el.classList.remove('unread');
  filterAlertas(document.getElementById('alerta-filter')?.value||'todas');
}

function atenderAlerta(id) {
  const lista = Store.get('alertas.lista');
  const a = lista.find(x=>x.id===id);
  if (a) { a.atendida = true; a.leida = true; }
  Store.set('alertas.lista', lista);
  if (!a.leida) Store.set('alertas.noLeidas', Math.max(Store.get('alertas.noLeidas')-1, 0));
  updateAlertBadge();
  Toast.show('Alerta atendida', 'success', 2000);
  filterAlertas(document.getElementById('alerta-filter')?.value||'todas');
}

function marcarTodasLeidas() {
  const lista = Store.get('alertas.lista');
  lista.forEach(a => a.leida = true);
  Store.set('alertas.lista', lista);
  Store.set('alertas.noLeidas', 0);
  updateAlertBadge();
  document.getElementById('alertas-list').innerHTML = renderAlertasList(lista);
}

function updateAlertBadge() {
  const n = Store.get('alertas.noLeidas');
  const b = document.getElementById('sidebar-alert-badge');
  if (b) { b.textContent = n; b.style.display = n > 0 ? '' : 'none'; }
}

