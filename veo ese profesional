function renderOCTable(ocs) {
  const badges = { borrador:'badge-gray', aprobada:'badge-blue', recibida:'badge-green', vencida:'badge-red' };
  return `<table><thead><tr><th>#OC</th><th>Proveedor</th><th>Fecha</th><th>Fecha Esp.</th><th>Total</th><th>Estado</th><th>Acciones</th></tr></thead>
    <tbody>${ocs.map(o => `<tr>
      <td class="td-mono">${o.id}</td>
      <td>${o.proveedor}</td>
      <td class="td-mono text-xs">${o.fecha}</td>
      <td class="td-mono text-xs ${o.estado==='vencida'?'text-red':''}">${o.fechaEsp}</td>
      <td class="td-mono text-amber">${fmt(o.total)}</td>
      <td><span class="badge ${badges[o.estado]||'badge-gray'}">${o.estado}</span></td>
      <td><div class="td-actions">
        <button class="btn btn-sm btn-ghost" onclick="verOCModal('${o.id}')">👁</button>
        ${o.estado==='aprobada'?`<button class="btn btn-sm btn-success" onclick="recibirOCModal('${o.id}')">📥 Recibir</button>`:''}
      </div></td>
    </tr>`).join('')}
    </tbody></table>`;
}

function filterOCs(estado) {
  const filtered = estado === 'todos' ? DB.ocs : DB.ocs.filter(o => o.estado === estado);
  document.getElementById('oc-table-body').innerHTML = renderOCTable(filtered);
}

