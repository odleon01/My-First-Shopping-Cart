let selectedPayMethod = null;

function iniciarCobro() {
  const c = getCarrito();
  if (c.lineas.length === 0) return;
  // Show cobro, hide catalog
  document.getElementById('catalog-panel').style.display = 'none';
  document.getElementById('cobro-view').classList.add('active');
  selectedPayMethod = null;
  pagoEfectivo = 0;
}

function volverAlCarrito() {
  document.getElementById('catalog-panel').style.display = 'flex';
  document.getElementById('cobro-view').classList.remove('active');
  document.getElementById('post-venta-view').classList.remove('active');
  document.getElementById('post-venta-view').style.display = 'none';
  document.getElementById('cobro-view').style.display = '';
}

function selectPayMethod(method) {
  selectedPayMethod = method;
  document.querySelectorAll('.pay-method-btn').forEach(b => b.classList.remove('selected'));
  const btn = document.getElementById('pay-' + method);
  if (btn) btn.classList.add('selected');
  const efPanel = document.getElementById('cobro-efectivo-panel');
  if (efPanel) {
    efPanel.style.display = method === 'efectivo' ? 'block' : 'none';
    if (method !== 'efectivo') {
      // Tarjeta o transferencia — cobro exacto automático
      const c = getCarrito();
      document.getElementById('pay-amt-' + method).textContent = fmt(c.total);
    }
  }
}

function setEfectivo(val) {
  const inp = document.getElementById('efectivo-input');
  if (inp) { inp.value = val; calcCambio(); }
}

function calcCambio() {
  const inp = document.getElementById('efectivo-input');
  if (!inp) return;
  const recibido = parseFloat(inp.value) || 0;
  pagoEfectivo = recibido;
  const c = getCarrito();
  const cambio = Math.max(recibido - c.total, 0);
  const recDisp = document.getElementById('rec-display');
  const camDisp = document.getElementById('cambio-display');
  const amtDisp = document.getElementById('pay-amt-efectivo');
  if (recDisp) recDisp.textContent = fmt(recibido);
  if (camDisp) camDisp.textContent = fmt(cambio);
  if (amtDisp) amtDisp.textContent = fmt(Math.min(recibido, c.total));
}

async function confirmarCobro() {
  if (!selectedPayMethod) {
    Toast.show('Selecciona un método de pago', 'warning'); return;
  }
  const c = getCarrito();
  if (selectedPayMethod === 'efectivo' && pagoEfectivo < c.total) {
    Toast.show('El monto recibido es insuficiente', 'error'); return;
  }
  await Loading.wrap(() => new Promise(r => setTimeout(r, 800)));
  const cambio = selectedPayMethod === 'efectivo' ? Math.max(pagoEfectivo - c.total, 0) : 0;
  const folio = 'V-' + Math.floor(Math.random()*9000+1000);
  // Update stock
  c.lineas.forEach(l => {
    const prod = DB.productos.find(p => p.id === l.prodId);
    if (prod) prod.stock = Math.max(prod.stock - l.qty, 0);
  });
  // Show post-venta
  document.getElementById('cobro-view').classList.remove('active');
  document.getElementById('cobro-view').style.display = 'none';
  const pvv = document.getElementById('post-venta-view');
  pvv.style.display = 'flex';
  pvv.classList.add('active');
  pvv.innerHTML = `
    <div class="success-circle">✓</div>
    <div style="font-family:var(--font-mono);font-size:13px;color:var(--text3);">VENTA COMPLETADA</div>
    <div class="pv-total">${fmt(c.total)}</div>
    <div class="pv-cambio">Folio: ${folio} · Cambio: <span style="color:var(--green);">${fmt(cambio)}</span></div>
    ${c.cliente ? `<div class="badge badge-amber">+${Math.floor(c.total/10)} puntos acumulados</div>` : ''}
    <div class="pv-actions">
      <button class="btn" onclick="imprimirTicket('${folio}')">🖨️ Imprimir</button>
      <button class="btn btn-primary btn-lg" onclick="nuevaVenta()">+ Nueva Venta</button>
    </div>`;
  // Add to today's stats
  DB.ventasHoy.total += c.total;
  DB.ventasHoy.transacciones += 1;
  DB.ventasHoy.ticketPromedio = round2(DB.ventasHoy.total / DB.ventasHoy.transacciones);
  Toast.show('Venta completada: ' + folio, 'success');
}

function imprimirTicket(folio) { Toast.show(`Ticket ${folio} enviado a la impresora`, 'info'); }

function nuevaVenta() {
  Store.set('pos.carritoActivo', { id: uid(), lineas:[], cliente:null, tipoDoc:'ticket', subtotal:0, descuento:0, impuestos:0, total:0, estado:'vacio' });
  document.getElementById('catalog-panel').style.display = 'flex';
  const pvv = document.getElementById('post-venta-view');
  pvv.style.display = 'none';
  pvv.classList.remove('active');
  const cv = document.getElementById('cobro-view');
  cv.style.display = '';
  cv.classList.remove('active');
  refreshCart();
  refreshCatalog();
  // Reset client button
  const btn = document.getElementById('pos-client-btn');
  if (btn) { btn.className = 'pos-client-btn'; btn.innerHTML = '👤 Sin cliente — clic para asignar'; }
}

