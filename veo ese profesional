    </table>`;
}

function renderTotals() {
  const c = getCarrito();
  return `
    <div class="total-row"><span class="total-label">Subtotal</span><span class="total-value">${fmt(c.subtotal)}</span></div>
    <div class="total-row"><span class="total-label">IVA (16%)</span><span class="total-value">${fmt(c.impuestos)}</span></div>
    <div class="total-row main"><span>TOTAL</span><span>${fmt(c.total)}</span></div>`;
}

function renderCatalogGrid() {
  let prods = DB.productos.filter(p => p.activo);
  if (catFilter !== 'Todos') prods = prods.filter(p => p.cat === catFilter);
  if (searchTerm) {
    const t = searchTerm.toLowerCase();
    prods = prods.filter(p => p.nombre.toLowerCase().includes(t) || p.sku.toLowerCase().includes(t));
  }
  if (prods.length === 0) return `<div class="empty-state" style="grid-column:1/-1;"><div class="empty-icon">🔍</div><p>Sin resultados</p></div>`;
  return prods.map(p => {
    const st = p.stock === 0 ? 'out-of-stock' : '';
    const sl = p.stock === 0 ? `<span class="product-stock-badge out">Sin stock</span>` :
               p.stock < p.stockMin ? `<span class="product-stock-badge low">⚡ ${p.stock} uds</span>` :
               `<span class="product-stock-badge ok">✓ ${p.stock} uds</span>`;
    return `<div class="product-card ${st}" onclick="addToCart('${p.id}')">
      <div class="product-name">${p.nombre}</div>
      <div class="product-price">${fmt(p.precio)}</div>
      ${sl}
    </div>`;
  }).join('');
}

function setCatFilter(cat) {
  catFilter = cat;
  document.querySelectorAll('.cat-chip').forEach(el => el.classList.toggle('active', el.textContent === cat));
  refreshCatalog();
}

function catalogSearch(val) {
  searchTerm = val;
  refreshCatalog();
}

function refreshCatalog() {
  const g = document.getElementById('catalog-grid');
  if (g) g.innerHTML = renderCatalogGrid();
}

function refreshCart() {
  const w = document.getElementById('cart-wrap');
  const t = document.getElementById('pos-totals');
  const b = document.getElementById('btn-cobrar');
  const c = getCarrito();
  if (w) w.innerHTML = renderCartTable();
  if (t) t.innerHTML = renderTotals();
  if (b) {
    b.disabled = c.lineas.length === 0;
    b.innerHTML = `💳 Cobrar ${c.total > 0 ? fmt(c.total) : ''}`;
  }
}

function calcTotals() {
  const c = getCarrito();
  const sub = round2(c.lineas.reduce((s, l) => s + l.precio * l.qty, 0));
  const imp = round2(sub * 0.16);
  const total = round2(sub + imp);
  Store.set('pos.carritoActivo.subtotal', sub);
  Store.set('pos.carritoActivo.impuestos', imp);
  Store.set('pos.carritoActivo.total', total);
  Store.set('pos.carritoActivo.estado', c.lineas.length > 0 ? 'con_productos' : 'vacio');
}

function addToCart(prodId) {
  const p = DB.productos.find(x => x.id === prodId);
  if (!p || p.stock === 0) return;
  const c = getCarrito();
  const existing = c.lineas.find(l => l.prodId === prodId);
  if (existing) {
    existing.qty += 1;
    Store.set('pos.carritoActivo.lineas', [...c.lineas]);
  } else {
    Store.set('pos.carritoActivo.lineas', [...c.lineas, { id: uid(), prodId, nombre: p.nombre, sku: p.sku, precio: p.precio, qty: 1 }]);
  }
  calcTotals();
  refreshCart();
  // Pulse animation on product card
  Toast.show(`${p.nombre} agregado al carrito`, 'success', 1500);
}

function removeFromCart(lineId) {
  const c = getCarrito();
  Store.set('pos.carritoActivo.lineas', c.lineas.filter(l => l.id !== lineId));
  calcTotals();
  refreshCart();
}

function updateQty(lineId, val) {
  const qty = parseInt(val);
  if (isNaN(qty) || qty < 1) { refreshCart(); return; }
  const c = getCarrito();
  const line = c.lineas.find(l => l.id === lineId);
  if (!line) return;
  const prod = DB.productos.find(p => p.id === line.prodId);
  if (prod && qty > prod.stock) {
    Toast.show(`Stock máximo disponible: ${prod.stock} uds`, 'warning');
    line.qty = prod.stock;
  } else {
    line.qty = qty;
  }
  Store.set('pos.carritoActivo.lineas', [...c.lineas]);
  calcTotals();
  refreshCart();
}

function cancelarVenta() {
  const c = getCarrito();
  if (c.lineas.length === 0) return;
  Modal.confirm('¿Cancelar la venta actual? Se perderán los productos en el carrito.', () => {
    Store.set('pos.carritoActivo.lineas', []);
    calcTotals();
    refreshCart();
    Toast.show('Venta cancelada', 'warning');
  });
}

