function renderInvTable(prods) {
  if (prods.length === 0) return `<div class="empty-state"><div class="empty-icon">🔍</div><p>Sin resultados</p></div>`;
  return `<table><thead><tr>
    <th>Producto</th><th>SKU</th><th>Categoría</th><th>Stock</th><th>Mín</th><th>Costo</th><th>Precio</th><th>Estado</th><th>Acciones</th>
  </tr></thead><tbody>
    ${prods.map(p => {
      const stClass = p.stock === 0 ? 'red' : p.stock < p.stockMin ? 'orange' : 'green';
      const stLabel = p.stock === 0 ? 'Sin stock' : p.stock < p.stockMin ? 'Stock bajo' : 'OK';
      const stBadge = p.stock === 0 ? 'badge-red' : p.stock < p.stockMin ? 'badge-orange' : 'badge-green';
      const pct = p.stockMin > 0 ? Math.min((p.stock / (p.stockMin * 2)) * 100, 100) : 100;
      const stDiv = `stock-${p.stock===0?'zero':p.stock<p.stockMin?'low':'ok'}`;
      return `<tr>
        <td><strong>${p.nombre}</strong></td>
        <td class="td-mono">${p.sku}</td>
        <td><span class="badge badge-gray">${p.cat}</span></td>
        <td>
          <div style="display:flex;align-items:center;gap:8px;">
            <span class="td-mono text-${stClass}" style="font-weight:600;">${p.stock}</span>
            <div class="stock-bar ${stDiv}"><div class="stock-bar-fill" style="width:${pct}%"></div></div>
          </div>
        </td>
        <td class="td-mono text-dim">${p.stockMin}</td>
        <td class="td-mono">${fmt(p.costo)}</td>
        <td class="td-mono text-amber">${fmt(p.precio)}</td>
        <td><span class="badge ${stBadge}">${stLabel}</span></td>
        <td>
          <div class="td-actions">
            <button class="btn btn-sm btn-ghost" onclick="editarProductoModal('${p.id}')">✏️</button>
            <button class="btn btn-sm btn-ghost" onclick="ajusteModal('${p.id}')">⚖️ Ajuste</button>
          </div>
        </td>
      </tr>`;
    }).join('')}
  </tbody></table>`;
}

let invFilter = { search:'', cat:'Todos', stock:'todos' };
function filterInvTable(v) { invFilter.search = v.toLowerCase(); applyInvFilter(); }
function filterInvCat(v)   { invFilter.cat = v; applyInvFilter(); }
function filterInvStock(v) { invFilter.stock = v; applyInvFilter(); }
function applyInvFilter() {
  let p = DB.productos;
  if (invFilter.cat !== 'Todos') p = p.filter(x => x.cat === invFilter.cat);
  if (invFilter.stock === 'bajo') p = p.filter(x => x.stock < x.stockMin && x.stock > 0);
  else if (invFilter.stock === 'sin') p = p.filter(x => x.stock === 0);
  else if (invFilter.stock === 'ok') p = p.filter(x => x.stock >= x.stockMin);
  if (invFilter.search) p = p.filter(x => x.nombre.toLowerCase().includes(invFilter.search) || x.sku.toLowerCase().includes(invFilter.search));
  document.getElementById('inv-table-body').innerHTML = renderInvTable(p);
}

