  Modal.close();
  await Loading.wrap(() => new Promise(r => setTimeout(r, 700)));
  const oc = DB.ocs.find(o => o.id === ocId);
  oc.estado = 'recibida';
  Toast.show(`OC ${ocId} recibida. Inventario actualizado.`, 'success');
  document.getElementById('oc-table-body').innerHTML = renderOCTable(DB.ocs);
}

