<style>
/* ===================================================
   VARIABLES Y RESET
=================================================== */
:root {
  --bg:        #0d0f14;
  --surface:   #161921;
  --surface2:  #1e2230;
  --border:    #2a2f42;
  --accent:    #f5c518;
  --accent2:   #e07b39;
  --text:      #e8eaf0;
  --text-muted:#7a8099;
  --success:   #4caf7d;
  --error:     #e05555;
  --radius:    10px;
  --font-head: 'Georgia', serif;
  --font-body: 'Courier New', monospace;
  --shadow:    0 4px 24px rgba(0,0,0,0.5);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.6;
  min-height: 100vh;
}

/* ===================================================
   HEADER
=================================================== */
#app-header {
  background: var(--surface);
  border-bottom: 2px solid var(--accent);
  padding: 18px 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: var(--shadow);
}

#app-header h1 {
  font-family: var(--font-head);
  font-size: 22px;
  letter-spacing: 2px;
  color: var(--accent);
}

#app-header h1 span {
  color: var(--accent2);
}

.header-stats {
  display: flex;
  gap: 24px;
}

.stat-chip {
  background: var(--surface2);
  border: 1px solid var(--border);
  padding: 4px 14px;
  border-radius: 20px;
  font-size: 12px;
  color: var(--text-muted);
}

.stat-chip strong {
  color: var(--accent);
  font-size: 14px;
}

/* ===================================================
   LAYOUT PRINCIPAL
=================================================== */
#main-layout {
  display: grid;
  grid-template-columns: 340px 1fr;
  gap: 0;
  min-height: calc(100vh - 64px);
}

/* ===================================================
   SIDEBAR (Formulario + Importar)
=================================================== */
#sidebar {
  background: var(--surface);
  border-right: 1px solid var(--border);
  padding: 24px 20px;
  overflow-y: auto;
}

.section-title {
  font-family: var(--font-head);
  font-size: 13px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 1px solid var(--border);
}

/* Formulario */
.form-group {
  margin-bottom: 12px;
}

.form-group label {
  display: block;
  font-size: 11px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 5px;
}

.form-group input {
  width: 100%;
  background: var(--surface2);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 9px 12px;
  border-radius: var(--radius);
  font-family: var(--font-body);
  font-size: 13px;
  transition: border-color 0.2s;
  outline: none;
}

.form-group input:focus {
  border-color: var(--accent);
}

.form-group input.error {
  border-color: var(--error);
}

.field-error {
  color: var(--error);
  font-size: 11px;
  margin-top: 3px;
  display: none;
}

.field-error.visible {
  display: block;
}

/* Botones */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 9px 18px;
  border: none;
  border-radius: var(--radius);
  font-family: var(--font-body);
  font-size: 13px;
  cursor: pointer;
  transition: all 0.18s;
  letter-spacing: 0.5px;
}

.btn-primary {
  background: var(--accent);
  color: #000;
  font-weight: bold;
  width: 100%;
  justify-content: center;
}

.btn-primary:hover { background: #ffd33a; transform: translateY(-1px); }

.btn-secondary {
  background: var(--surface2);
  color: var(--text);
  border: 1px solid var(--border);
  width: 100%;
  justify-content: center;
}

.btn-secondary:hover { border-color: var(--accent2); color: var(--accent2); }

.btn-danger {
  background: transparent;
  color: var(--error);
  border: 1px solid var(--error);
  padding: 5px 10px;
  font-size: 11px;
}

.btn-danger:hover { background: var(--error); color: #fff; }

.btn-print {
  background: var(--accent2);
  color: #fff;
  font-weight: bold;
}

.btn-print:hover { background: #f0923e; }

.btn-clear {
  background: transparent;
  color: var(--error);
  border: 1px solid var(--error);
  width: 100%;
  justify-content: center;
  margin-top: 6px;
}

.btn-clear:hover { background: var(--error); color: #fff; }

/* Separador */
.divider {
  border: none;
  border-top: 1px solid var(--border);
  margin: 20px 0;
}

/* Zona de importación */
.import-zone {
  background: var(--surface2);
  border: 2px dashed var(--border);
  border-radius: var(--radius);
  padding: 18px;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
  margin-bottom: 10px;
}

.import-zone:hover {
  border-color: var(--accent);
  background: #1a2035;
}

.import-zone .icon { font-size: 28px; display: block; margin-bottom: 6px; }
.import-zone p { color: var(--text-muted); font-size: 12px; }
.import-zone strong { color: var(--accent); }

#file-input { display: none; }

/* Instrucciones Excel */
.excel-guide {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px;
  margin-top: 14px;
}

.excel-guide h4 {
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--accent2);
  margin-bottom: 10px;
}

.excel-guide table {
  width: 100%;
  border-collapse: collapse;
  font-size: 11px;
}

.excel-guide th {
  background: var(--bg);
  color: var(--accent);
  padding: 4px 6px;
  text-align: left;
  border: 1px solid var(--border);
}

.excel-guide td {
  padding: 3px 6px;
  border: 1px solid var(--border);
  color: var(--text-muted);
}

.excel-guide .note {
  font-size: 10px;
  color: var(--text-muted);
  margin-top: 8px;
  line-height: 1.5;
}

.excel-guide .note span { color: var(--accent2); }

/* ===================================================
   ÁREA DE CATÁLOGO
=================================================== */
#catalog-area {
  padding: 24px;
  overflow-y: auto;
}

/* Toolbar búsqueda + acciones */
#toolbar {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}

#search-input {
  flex: 1;
  min-width: 200px;
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 9px 14px;
  border-radius: var(--radius);
  font-family: var(--font-body);
  font-size: 13px;
  outline: none;
  transition: border-color 0.2s;
}

#search-input:focus { border-color: var(--accent); }
#search-input::placeholder { color: var(--text-muted); }

/* Grid de productos */
#product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 16px;
}

/* Tarjeta producto */
.product-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  transition: all 0.2s;
  position: relative;
}

.product-card:hover {
  border-color: var(--accent);
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(245, 197, 24, 0.1);
}

.card-image {
  width: 100%;
  height: 130px;
  object-fit: contain;
  background: var(--surface2);
  display: block;
}

.card-image-placeholder {
  width: 100%;
  height: 130px;
  background: var(--surface2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36px;
  color: var(--border);
}

.card-body {
  padding: 12px;
}

.card-name {
  font-family: var(--font-head);
  font-size: 14px;
  color: var(--text);
  margin-bottom: 4px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-sku {
  font-size: 11px;
  color: var(--text-muted);
  letter-spacing: 1px;
  margin-bottom: 8px;
}

.card-prices {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
}

.price-public {
  font-size: 13px;
  color: var(--text);
}

.price-socio {
  font-size: 13px;
  color: var(--accent);
  font-weight: bold;
}

.price-label {
  font-size: 10px;
  color: var(--text-muted);
  display: block;
}

.card-barcode {
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 4px 0;
  background: white;
  border-radius: 4px;
  margin-bottom: 10px;
}

.card-barcode svg {
  max-width: 100%;
  height: 40px;
}

.card-actions {
  display: flex;
  gap: 6px;
}

/* Estado vacío */
#empty-state {
  grid-column: 1/-1;
  text-align: center;
  padding: 60px 20px;
  color: var(--text-muted);
}

#empty-state .empty-icon { font-size: 56px; display: block; margin-bottom: 14px; }
#empty-state h3 { font-family: var(--font-head); font-size: 18px; color: var(--text); margin-bottom: 8px; }
#empty-state p { font-size: 13px; }

/* Toast / Feedback */
#toast {
  position: fixed;
  bottom: 28px;
  right: 28px;
  padding: 12px 22px;
  border-radius: var(--radius);
  font-size: 13px;
  font-family: var(--font-body);
  z-index: 9999;
  transform: translateY(80px);
  opacity: 0;
  transition: all 0.3s;
  max-width: 320px;
}

#toast.show { transform: translateY(0); opacity: 1; }
#toast.success { background: var(--success); color: #fff; }
#toast.error   { background: var(--error);   color: #fff; }
#toast.info    { background: var(--accent2); color: #fff; }

/* ===================================================
   MODAL EDICIÓN
=================================================== */
#modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.7);
  z-index: 200;
  align-items: center;
  justify-content: center;
}

#modal-overlay.active { display: flex; }

#modal-box {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 28px;
  width: 90%;
  max-width: 420px;
  box-shadow: var(--shadow);
}

#modal-box h3 {
  font-family: var(--font-head);
  color: var(--accent);
  margin-bottom: 20px;
}

.modal-actions {
  display: flex;
  gap: 10px;
  margin-top: 16px;
}

.modal-actions .btn { flex: 1; justify-content: center; }

/* ===================================================
   VISTA DE IMPRESIÓN
=================================================== */
@media screen {
  #print-preview { display: none; }
}

@media print {
  body > *:not(#print-preview) { display: none !important; }

  #print-preview {
    display: block !important;
    margin: 0;
    padding: 0;
  }

  @page {
    size: letter portrait;
    margin: 10mm 8mm;
  }

  .print-page {
    width: 100%;
    page-break-after: always;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: repeat(6, auto);
    gap: 6mm;
  }

  .print-page:last-child {
    page-break-after: avoid;
  }

  .print-item {
    border: 1px solid #ccc;
    border-radius: 4px;
    padding: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: Arial, sans-serif;
    font-size: 9px;
  }

  .print-item img.prod-img {
    width: auto;
    height: 55px;
    object-fit: contain;
    margin-bottom: 4px;
  }

  .print-item .print-name {
    font-weight: bold;
    font-size: 10px;
    text-align: center;
    margin-bottom: 2px;
    max-width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .print-item .print-sku {
    color: #666;
    font-size: 8px;
    margin-bottom: 4px;
  }

  .print-prices {
    display: flex;
    gap: 10px;
    margin-bottom: 4px;
  }

  .print-price-block { text-align: center; }
  .print-price-label { font-size: 7px; color: #888; display: block; }
  .print-price-val { font-size: 10px; font-weight: bold; }
  .print-price-val.socio { color: #c07000; }

  .print-barcode svg {
    width: 100%;
    height: 32px;
    max-width: 160px;
  }
}

/* ===================================================
   RESPONSIVE
=================================================== */
@media (max-width: 820px) {
  #main-layout { grid-template-columns: 1fr; }
  #sidebar { border-right: none; border-bottom: 1px solid var(--border); }
}
</style>

