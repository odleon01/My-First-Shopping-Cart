/* --------------------------------------------------------
   RENDERIZAR CATÁLOGO
-------------------------------------------------------- */
function renderCatalog() {
  const grid = document.getElementById('product-grid');
  const filtered = getFilteredProducts();

  // Estadísticas
  document.getElementById('stat-total').textContent    = products.length;
  document.getElementById('stat-filtered').textContent = filtered.length;

  if (filtered.length === 0) {
    grid.innerHTML = `
      <div id="empty-state">
        <span class="empty-icon">${products.length === 0 ? '📦' : '🔍'}</span>
        <h3>${products.length === 0 ? 'Sin productos aún' : 'Sin resultados'}</h3>
        <p>${products.length === 0 ? 'Agrega productos con el formulario o importa desde Excel.' : 'Prueba con otro término de búsqueda.'}</p>
      </div>`;
    return;
  }

  grid.innerHTML = filtered.map(p => `
    <div class="product-card" data-id="${p.id}">
      ${p.imagen
        ? `<img class="card-image" src="${escapeHtml(p.imagen)}" alt="${escapeHtml(p.nombre)}" onerror="this.style.display='none';this.nextSibling.style.display='flex'">`
        : ''
      }
      <div class="card-image-placeholder" ${p.imagen ? 'style="display:none"' : ''}>📦</div>
      <div class="card-body">
        <div class="card-name" title="${escapeHtml(p.nombre)}">${escapeHtml(p.nombre)}</div>
        <div class="card-sku">SKU: ${escapeHtml(p.sku)}</div>
        <div class="card-prices">
          <div>
            <span class="price-label">Público</span>
            <span class="price-public">$${formatPrice(p.precioPub)}</span>
          </div>
          <div>
            <span class="price-label">Socio</span>
            <span class="price-socio">$${formatPrice(p.precioSocio)}</span>
          </div>
        </div>
        <div class="card-barcode">
          <svg id="bc-${p.id}"></svg>
        </div>
        <div class="card-actions">
          <button class="btn btn-secondary" style="flex:1;font-size:11px;padding:5px" onclick="editProduct(${p.id})">✏️ Editar</button>
          <button class="btn btn-danger" onclick="deleteProduct(${p.id})">🗑</button>
        </div>
      </div>
    </div>
  `).join('');

  // Generar códigos de barra después de insertar el HTML
  filtered.forEach(p => {
    try {
      JsBarcode(`#bc-${p.id}`, p.barcode, {
        format:      'CODE128',
        width:       1.4,
        height:      35,
        displayValue: false,
        margin:      2,
        background:  '#ffffff',
        lineColor:   '#000000',
      });
    } catch(e) {
      // Si el código es inválido para CODE128, mostrar texto
      const el = document.getElementById(`bc-${p.id}`);
      if (el) el.outerHTML = `<span style="font-size:10px;color:#888;padding:4px">⚠ Código inválido</span>`;
    }
  });
}

/* --------------------------------------------------------
   IMPRIMIR CATÁLOGO
-------------------------------------------------------- */
function printCatalog() {
  const filtered = getFilteredProducts();

  if (filtered.length === 0) {
    showToast('No hay productos para imprimir', 'info');
    return;
  }

  const preview = document.getElementById('print-preview');
  preview.innerHTML = '';

  // Chunk en páginas de 12 (6 filas x 2 columnas)
  const pages = chunkArray(filtered, 12);

  pages.forEach(page => {
    const pageDiv = document.createElement('div');
    pageDiv.className = 'print-page';

    page.forEach(p => {
      const item = document.createElement('div');
      item.className = 'print-item';

      let barcodeHTML = '';
      try {
        // Crear SVG temporal para el barcode
        const tempSvg = document.createElementNS('http://www.w3.org/2000/svg','svg');
        tempSvg.id = `pbc-${p.id}`;
        document.body.appendChild(tempSvg);
        JsBarcode(`#pbc-${p.id}`, p.barcode, {
          format: 'CODE128', width: 1.2, height: 28,
          displayValue: false, margin: 2,
          background: '#ffffff', lineColor: '#000000'
        });
        barcodeHTML = `<div class="print-barcode">${tempSvg.outerHTML}</div>`;
        document.body.removeChild(tempSvg);
      } catch(e) {
        barcodeHTML = `<div class="print-barcode"><span style="font-size:8px;color:#888">Cód: ${escapeHtml(p.barcode)}</span></div>`;
      }

      item.innerHTML = `
        ${p.imagen ? `<img class="prod-img" src="${escapeHtml(p.imagen)}" alt="">` : ''}
        <div class="print-name">${escapeHtml(p.nombre)}</div>
        <div class="print-sku">SKU: ${escapeHtml(p.sku)}</div>
        <div class="print-prices">
          <div class="print-price-block">
            <span class="print-price-label">Precio Público</span>
            <span class="print-price-val">$${formatPrice(p.precioPub)}</span>
          </div>
          <div class="print-price-block">
            <span class="print-price-label">Precio Socio</span>
            <span class="print-price-val socio">$${formatPrice(p.precioSocio)}</span>
          </div>
        </div>
        ${barcodeHTML}
      `;
      pageDiv.appendChild(item);
    });

    preview.appendChild(pageDiv);
  });

  window.print();
}

/* --------------------------------------------------------
   UTILIDADES
-------------------------------------------------------- */
function escapeHtml(str) {
  return String(str)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;');
}

function formatPrice(n) {
  const num = parseFloat(n) || 0;
  return num.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
}

function chunkArray(arr, size) {
  const chunks = [];
  for (let i = 0; i < arr.length; i += size) {
    chunks.push(arr.slice(i, i + size));
  }
  return chunks;
}

