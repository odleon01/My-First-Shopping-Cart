<script>
/* --------------------------------------------------------
   ESTADO GLOBAL
-------------------------------------------------------- */
let products = [];  // Array de productos en memoria
let nextId = 1;     // ID autoincremental

/* --------------------------------------------------------
   PERSISTENCIA (localStorage)
-------------------------------------------------------- */
function saveToStorage() {
  try {
    localStorage.setItem('catalogopro_products', JSON.stringify(products));
    localStorage.setItem('catalogopro_nextid', nextId);
  } catch(e) {
    console.warn('No se pudo guardar en localStorage:', e);
  }
}

function loadFromStorage() {
  try {
    const data = localStorage.getItem('catalogopro_products');
    const id   = localStorage.getItem('catalogopro_nextid');
    if (data) products = JSON.parse(data);
    if (id)   nextId   = parseInt(id);
  } catch(e) {
    products = [];
    nextId = 1;
  }
}

/* --------------------------------------------------------
   TOAST (feedback)
-------------------------------------------------------- */
let toastTimer;
function showToast(msg, type = 'success') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = `show ${type}`;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => { el.className = ''; }, 3000);
}

/* --------------------------------------------------------
   VALIDACIÓN
-------------------------------------------------------- */
function validateForm(prefix) {
  const fields = {
    nombre:      { id: `${prefix}-nombre`,       errId: `err-${prefix === 'f' ? '' : ''}nombre` },
    sku:         { id: `${prefix}-sku`,           errId: 'err-sku' },
    'precio-pub':  { id: `${prefix}-precio-pub`,  errId: 'err-precio-pub' },
    'precio-socio':{ id: `${prefix}-precio-socio`,errId: 'err-precio-socio' },
    barcode:     { id: `${prefix}-barcode`,       errId: 'err-barcode' },
  };

  let valid = true;

  // Solo para el formulario principal
  if (prefix === 'f') {
    const checks = [
      { el: document.getElementById('f-nombre'),      err: document.getElementById('err-nombre'),      test: v => v.trim().length > 0 },
      { el: document.getElementById('f-sku'),         err: document.getElementById('err-sku'),         test: v => v.trim().length > 0 },
      { el: document.getElementById('f-precio-pub'),  err: document.getElementById('err-precio-pub'),  test: v => v !== '' && parseFloat(v) >= 0 },
      { el: document.getElementById('f-precio-socio'),err: document.getElementById('err-precio-socio'),test: v => v !== '' && parseFloat(v) >= 0 },
      { el: document.getElementById('f-barcode'),     err: document.getElementById('err-barcode'),     test: v => v.trim().length > 0 && /^[A-Za-z0-9\-\s]+$/.test(v.trim()) },
    ];
    checks.forEach(c => {
      const ok = c.test(c.el.value);
      c.el.classList.toggle('error', !ok);
      c.err.classList.toggle('visible', !ok);
      if (!ok) valid = false;
    });
  }

  return valid;
}

/* --------------------------------------------------------
   AGREGAR PRODUCTO (formulario manual)
-------------------------------------------------------- */
function addProduct() {
  if (!validateForm('f')) return;

  const product = {
    id:          nextId++,
    nombre:      document.getElementById('f-nombre').value.trim(),
    sku:         document.getElementById('f-sku').value.trim(),
    precioPub:   parseFloat(document.getElementById('f-precio-pub').value),
    precioSocio: parseFloat(document.getElementById('f-precio-socio').value),
    barcode:     document.getElementById('f-barcode').value.trim(),
    imagen:      document.getElementById('f-imagen').value.trim(),
  };

  products.push(product);
  saveToStorage();
  renderCatalog();
  clearForm();
  showToast(`✔ "${product.nombre}" agregado`, 'success');
}

function clearForm() {
  ['f-nombre','f-sku','f-precio-pub','f-precio-socio','f-barcode','f-imagen'].forEach(id => {
    document.getElementById(id).value = '';
    document.getElementById(id).classList.remove('error');
  });
  ['err-nombre','err-sku','err-precio-pub','err-precio-socio','err-barcode'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.remove('visible');
  });
}

/* --------------------------------------------------------
   ELIMINAR PRODUCTO
-------------------------------------------------------- */
function deleteProduct(id) {
  products = products.filter(p => p.id !== id);
  saveToStorage();
  renderCatalog();
  showToast('Producto eliminado', 'info');
}

/* --------------------------------------------------------
   EDITAR PRODUCTO (abrir modal)
-------------------------------------------------------- */
function editProduct(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  document.getElementById('m-id').value           = p.id;
  document.getElementById('m-nombre').value        = p.nombre;
  document.getElementById('m-sku').value           = p.sku;
  document.getElementById('m-precio-pub').value    = p.precioPub;
  document.getElementById('m-precio-socio').value  = p.precioSocio;
  document.getElementById('m-barcode').value       = p.barcode;
  document.getElementById('m-imagen').value        = p.imagen || '';
  document.getElementById('modal-overlay').classList.add('active');
}

function closeModal(e) {
  if (e.target.id === 'modal-overlay') {
    document.getElementById('modal-overlay').classList.remove('active');
  }
}

function saveEdit() {
  const id = parseInt(document.getElementById('m-id').value);
  const idx = products.findIndex(p => p.id === id);
  if (idx === -1) return;

  products[idx] = {
    id,
    nombre:      document.getElementById('m-nombre').value.trim(),
    sku:         document.getElementById('m-sku').value.trim(),
    precioPub:   parseFloat(document.getElementById('m-precio-pub').value),
    precioSocio: parseFloat(document.getElementById('m-precio-socio').value),
    barcode:     document.getElementById('m-barcode').value.trim(),
    imagen:      document.getElementById('m-imagen').value.trim(),
  };

  saveToStorage();
  renderCatalog();
  document.getElementById('modal-overlay').classList.remove('active');
  showToast('✔ Producto actualizado', 'success');
}

/* --------------------------------------------------------
   IMPORTAR EXCEL / CSV
-------------------------------------------------------- */
function importFile(event) {
  const file = event.target.files[0];
  if (!file) return;

  const ext = file.name.split('.').pop().toLowerCase();
  const reader = new FileReader();

  reader.onload = function(e) {
    try {
      let rows = [];

      if (ext === 'csv') {
        // Parsear CSV simple
        const text = e.target.result;
        rows = parseCSV(text);
      } else {
        // Parsear XLSX con SheetJS
        const data = new Uint8Array(e.target.result);
        const wb   = XLSX.read(data, { type: 'array', cellText: true, raw: false });
        const ws   = wb.Sheets[wb.SheetNames[0]];
        rows       = XLSX.utils.sheet_to_json(ws, { defval: '', raw: false });
      }

      if (!rows || rows.length === 0) {
        showToast('El archivo está vacío', 'error');
        return;
      }

      // Verificar columnas obligatorias
      const required = ['nombre','sku','precio_publico','precio_socio','codigo_barras'];
      const headers = Object.keys(rows[0]).map(h => h.toLowerCase().trim());
      const missing = required.filter(r => !headers.includes(r));

      if (missing.length > 0) {
        showToast(`Columnas faltantes: ${missing.join(', ')}`, 'error');
        return;
      }

      let added = 0, skipped = 0;

      rows.forEach(row => {
        // Normalizar claves (case insensitive)
        const r = {};
        Object.keys(row).forEach(k => { r[k.toLowerCase().trim()] = row[k]; });

        const nombre   = String(r['nombre'] || '').trim();
        const sku      = String(r['sku'] || '').trim();
        const pPub     = parseFloat(r['precio_publico']) || 0;
        const pSocio   = parseFloat(r['precio_socio']) || 0;
        const barcode  = String(r['codigo_barras'] || '').trim();
        const imagen   = String(r['imagen'] || '').trim();

        // Validar mínimos
        if (!nombre || !sku || !barcode) { skipped++; return; }
        // Validar barcode (solo alfanumérico)
        if (!/^[A-Za-z0-9\-\s]+$/.test(barcode)) { skipped++; return; }

        products.push({ id: nextId++, nombre, sku, precioPub: pPub, precioSocio: pSocio, barcode, imagen });
        added++;
      });

      saveToStorage();
      renderCatalog();
      showToast(`✔ ${added} producto(s) importado(s)${skipped > 0 ? `, ${skipped} omitido(s)` : ''}`, 'success');

    } catch(err) {
      console.error(err);
      showToast('Error al procesar el archivo. Revisa el formato.', 'error');
    }
  };

  if (ext === 'csv') {
    reader.readAsText(file, 'UTF-8');
  } else {
    reader.readAsArrayBuffer(file);
  }

  // Resetear input para poder importar el mismo archivo otra vez
  event.target.value = '';
}

/* Parseador CSV manual simple */
function parseCSV(text) {
  const lines = text.split('\n').filter(l => l.trim());
  if (lines.length < 2) return [];
  const headers = lines[0].split(',').map(h => h.replace(/"/g,'').trim().toLowerCase());
  const rows = [];
  for (let i = 1; i < lines.length; i++) {
    const vals = lines[i].split(',').map(v => v.replace(/"/g,'').trim());
    const obj = {};
    headers.forEach((h, idx) => { obj[h] = vals[idx] || ''; });
    rows.push(obj);
  }
  return rows;
}

